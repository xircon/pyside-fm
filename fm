    def open_with(self) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            return
        dialog = OpenWithDialog(self)
        if dialog.exec() != QDialog.DialogCode.Accepted or not dialog.command():
            return
        command = shutil.which(dialog.command()) or dialog.command()
        try:
            reap_when_finished(subprocess.Popen([command, *[str(path) for path in paths]], cwd=str(self.current_path())))
        except OSError as exc:
            QMessageBox.warning(self, "Open With Failed", str(exc))

    def open_with_desktop(self, exec_line: str) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            return
        try:
            command = desktop_exec_command(exec_line, paths)
            if command:
                reap_when_finished(subprocess.Popen(command, cwd=str(self.current_path())))
        except OSError as exc:
            QMessageBox.warning(self, "Open With Failed", str(exc))

    def new_folder(self) -> None:
        name, ok = get_name(self, "New Folder", "Name")
        if not ok or not name.strip():
            return
        target = self.current_path() / name.strip()
        try:
            target.mkdir()
            self.record_undo(UndoAction("created", [(target, Path())]))
        except OSError as exc:
            QMessageBox.warning(self, "New Folder Failed", str(exc))

    def new_file(self) -> None:
        name, ok = get_name(self, "New File", "Name")
        if not ok or not name.strip():
            return
        target = self.current_path() / name.strip()
        try:
            target.touch(exist_ok=False)
            self.record_undo(UndoAction("created", [(target, Path())]))
        except OSError as exc:
            QMessageBox.warning(self, "New File Failed", str(exc))

    def rename_selected(self) -> None:
