    def calculate_selected_size(self) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            paths = [self.current_path()]
        total = files = folders = 0
        progress = QProgressDialog("Calculating size...", "Cancel", 0, len(paths), self)
        widen_progress_dialog(progress)
        progress.setWindowModality(Qt.WindowModality.WindowModal)
        progress.setMinimumDuration(0)
        progress.show()
        for row, path in enumerate(paths):
            progress.setValue(row)
            progress.setLabelText(f"Calculating: {path.name or path}")
            QApplication.processEvents()
            if progress.wasCanceled():
                return
            size, file_count, folder_count = directory_size(path)
            total += size
            files += file_count
            folders += folder_count
        progress.setValue(len(paths))
        QMessageBox.information(
            self,
            "Directory Size",
            f"Size: {readable_size(total)}\nFiles: {files}\nFolders: {folders}",
        )

