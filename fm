    def current_view(self) -> QAbstractItemView:
        return self.stack.currentWidget()

    def current_path(self) -> Path:
        return self.path

    def selected_paths(self) -> list[Path]:
        view = self.current_view()
        indexes = view.selectionModel().selectedRows(0)
        return [Path(self.model.filePath(index)) for index in indexes if index.isValid()]

    def tagged_paths(self) -> list[Path]:
        live_tags = []
        for path in self._tagged_paths:
            if path.exists():
                live_tags.append(path)
        if len(live_tags) != len(self._tagged_paths):
            self._tagged_paths = set(live_tags)
            self.model.set_tagged_paths(self._tagged_paths)
        return sorted(live_tags, key=lambda path: path.name.casefold())

    def operation_paths(self) -> list[Path]:
        tags = self.tagged_paths()
        return tags if tags else self.selected_or_current_paths()

    def selected_or_current_paths(self) -> list[Path]:
        paths = self.selected_paths()
        if paths:
            return paths
        index = self.current_view().currentIndex()
        if index.isValid():
            return [Path(self.model.filePath(index))]
        return []

    def current_item_path(self) -> Path | None:
        paths = self.selected_or_current_paths()
        return paths[0] if paths else None

    def toggle_detail_tag(self) -> None:
        self.toggle_current_tag()

    def toggle_current_tag(self) -> None:
        view = self.current_view()
        index = view.currentIndex()
        if not index.isValid():
            first_index = self.model.index(0, 0, view.rootIndex())
            if first_index.isValid():
                view.setCurrentIndex(first_index)
            return

        row_index = index.siblingAtColumn(0)
        if not row_index.isValid():
            row_index = self.model.index(index.row(), 0, index.parent())
        path = Path(self.model.filePath(row_index))
        if path in self._tagged_paths:
            self._tagged_paths.remove(path)
        else:
            self._tagged_paths.add(path)
        self.model.set_tagged_paths(self._tagged_paths)

        current_after_tag = self._next_tag_index(view, row_index)
        if current_after_tag.isValid():
            view.scrollTo(current_after_tag, QAbstractItemView.ScrollHint.EnsureVisible)
        self._sync_tag_selection(view, current_after_tag)
        self._update_status()

    def _next_tag_index(self, view: QAbstractItemView, row_index: QModelIndex) -> QModelIndex:
        if view is self.detail_view:
            next_index = self.detail_view.indexBelow(row_index)
            if next_index.isValid():
                return next_index.siblingAtColumn(0)
        next_index = self.model.index(row_index.row() + 1, 0, row_index.parent())
        return next_index if next_index.isValid() else row_index

    def _sync_detail_tag_selection(self, current_index: QModelIndex | None = None) -> None:
        self._sync_tag_selection(self.detail_view, current_index)

    def _sync_tag_selection(self, view: QAbstractItemView, current_index: QModelIndex | None = None) -> None:
        selection_model = view.selectionModel()
        selection_model.clearSelection()
        for path in sorted(self._tagged_paths, key=lambda item: item.name.casefold()):
            index = self.model.index(str(path)).siblingAtColumn(0)
            if index.isValid():
                selection_model.select(index, QItemSelectionModel.SelectionFlag.Select | QItemSelectionModel.SelectionFlag.Rows)
        if current_index and current_index.isValid():
            selection_model.setCurrentIndex(current_index, QItemSelectionModel.SelectionFlag.NoUpdate)

    def clear_selection(self) -> None:
        self._tagged_paths.clear()
        self.model.set_tagged_paths(self._tagged_paths)
        for view in self.views:
            view.selectionModel().clearSelection()
        self._update_status()

    def set_path(self, path: Path, *, add_history: bool = True) -> None:
        expanded = path.expanduser()
        try:
            resolved = expanded.resolve()
        except OSError:
            resolved = expanded
        if not resolved.exists() or not resolved.is_dir():
            QMessageBox.warning(self, "Folder Not Found", f"Cannot open:\n{resolved}")
            return
        self._tagged_paths.clear()
        self.model.set_tagged_paths(self._tagged_paths)
        self.path = resolved

        index = self.model.setRootPath(str(resolved))
        for view in self.views:
            view.setRootIndex(index)
        display_path = display_path_label(resolved)
        self.path_edit.setText(display_path)
        self.path_edit.setCursorPosition(len(display_path))
        self.path_edit.setToolTip(str(resolved))

        if add_history and not self._changing_history:
            if self._history_index < len(self._history) - 1:
                self._history = self._history[: self._history_index + 1]
            if not self._history or self._history[-1] != resolved:
                self._history.append(resolved)
                self._history_index = len(self._history) - 1
        self._update_navigation()
        self._update_breadcrumbs()
        self._update_status()
        window = self.window()
        if hasattr(window, "record_recent_path"):
            window.record_recent_path(resolved)

    def set_view_mode(self, mode: str) -> None:
        if mode not in VIEW_MODES:
            mode = "Details"
        if self.manual_preview_active:
            self.close_manual_preview()
        self.view_combo.blockSignals(True)
        self.view_combo.setCurrentText(mode)
        self.view_combo.blockSignals(False)
        self.stack.setCurrentIndex(VIEW_MODES.index(mode))
        self.current_view().setFocus()
        self._sync_current_selection()

    def _sync_current_selection(self) -> None:
        current = self.current_item_path()
        if not current:
            return
        index = self.model.index(str(current))
        if index.isValid():
            self.current_view().selectionModel().select(
                index,
                QItemSelectionModel.SelectionFlag.ClearAndSelect | QItemSelectionModel.SelectionFlag.Rows,
            )
            self.current_view().setCurrentIndex(index)

    def _path_entered(self) -> None:
        text = self.path_edit.text().strip()
        if text == "/h/x":
            text = str(Path.home())
        elif text.startswith("/h/x/"):
            text = str(Path.home()) + "/" + text[5:]
        elif text.startswith("/h/"):
            text = str(Path.home()) + "/" + text[3:]
        elif text == "~":
            text = str(Path.home())
        self.set_path(Path(text))

    def _update_breadcrumbs(self) -> None:
        while self.breadcrumb_layout.count():
            item = self.breadcrumb_layout.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()
        parts = self._breadcrumb_parts()
        labels = self._breadcrumb_labels(parts)
        for index, ((_, target), label) in enumerate(zip(parts, labels)):
            if index:
                self.breadcrumb_layout.addWidget(QLabel("/"))
            button = QToolButton()
            button.setText(label)
            button.setToolTip(str(target))
            button.setToolButtonStyle(Qt.ToolButtonStyle.ToolButtonTextOnly)
            button.clicked.connect(lambda _checked=False, p=target, pane=self: pane.set_path(p))
            self.breadcrumb_layout.addWidget(button)
        self.breadcrumb_layout.addStretch(1)

    def _breadcrumb_parts(self) -> list[tuple[str, Path]]:
        path = self.current_path()
        home = Path.home()
        try:
            relative = path.relative_to(home)
        except ValueError:
            parts: list[tuple[str, Path]] = []
            current = path.anchor
            if current:
                root_path = Path(current)
                parts.append((current.rstrip("/") or "/", root_path))
                relative = path.relative_to(root_path) if path != root_path else Path()
            else:
                relative = path
            running = Path(path.anchor) if path.anchor else Path()
            for part in relative.parts:
                running = running / part
                parts.append((part, running))
            return parts

        parts = [("~", home)]
        running = home
        for part in relative.parts:
            running = running / part
            parts.append((part, running))
        return parts

    def _breadcrumb_labels(self, parts: list[tuple[str, Path]]) -> list[str]:
        labels = [label for label, _ in parts]
        if self._breadcrumb_labels_fit(labels):
            return labels
        labels = [label for label, _ in parts]
        for index in range(max(0, len(labels) - 1)):
            labels[index] = compact_breadcrumb_label(labels[index])
            if self._breadcrumb_labels_fit(labels):
                return labels
        return labels

    def _breadcrumb_labels_fit(self, labels: list[str]) -> bool:
        if not labels:
            return True
        available = max(80, self.width() - 24)
        metrics = self.fontMetrics()
        total = 24
        for label in labels:
            total += metrics.horizontalAdvance(label) + 34
        total += max(0, len(labels) - 1) * (metrics.horizontalAdvance("/") + 10)
        return total <= available

    def go_back(self) -> None:
        if self._history_index <= 0:
            return
        self._history_index -= 1
        self._changing_history = True
        self.set_path(self._history[self._history_index], add_history=False)
        self._changing_history = False

    def go_forward(self) -> None:
        if self._history_index >= len(self._history) - 1:
            return
        self._history_index += 1
        self._changing_history = True
        self.set_path(self._history[self._history_index], add_history=False)
        self._changing_history = False

    def go_up(self) -> None:
        parent = self.current_path().parent
        if parent != self.current_path():
            self.set_path(parent)

    def refresh(self) -> None:
        path = self.current_path()
        self.model.setRootPath("")
        self.set_path(path, add_history=False)

