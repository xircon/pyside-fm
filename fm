def directory_size(path: Path) -> tuple[int, int, int]:
    if not path.is_dir() or path.is_symlink():
        try:
            return path.stat().st_size, 1, 0
        except OSError:
            return 0, 0, 0
    total = 0
    files = 0
    folders = 0
    for root, dirs, filenames in os.walk(path):
        folders += len(dirs)
        files += len(filenames)
        for filename in filenames:
            try:
                total += (Path(root) / filename).stat().st_size
            except OSError:
                pass
    return total, files, folders


def file_mime_type(path: Path) -> str:
    info = QFileInfo(str(path))
    if info.isDir():
        return "inode/directory"
    mime, _encoding = mimetypes.guess_type(path.name)
    return mime or "application/octet-stream"


def is_previewable_file(path: Path) -> bool:
    suffix = path.suffix.lower()
    if suffix in IMAGE_EXTENSIONS or suffix in PDF_EXTENSIONS or suffix in TEXT_EXTENSIONS:
        return True
    return file_mime_type(path).startswith("text/")


def desktop_files() -> list[Path]:
    roots = [
        Path.home() / ".local" / "share" / "applications",
        Path("/usr/local/share/applications"),
        Path("/usr/share/applications"),
    ]
    files: list[Path] = []
    for root in roots:
        if root.exists():
            files.extend(sorted(root.glob("*.desktop")))
    return files


def read_desktop_entry(path: Path) -> dict[str, str] | None:
    parser = configparser.ConfigParser(interpolation=None)
    parser.optionxform = str
    try:
        parser.read(path, encoding="utf-8")
    except configparser.Error:
        return None
    if not parser.has_section("Desktop Entry"):
        return None
    entry = dict(parser.items("Desktop Entry"))
    if entry.get("Type") != "Application" or entry.get("NoDisplay", "").lower() == "true":
        return None
    if entry.get("Hidden", "").lower() == "true" or entry.get("Terminal", "").lower() == "true":
        return None
    if not entry.get("Name") or not entry.get("Exec"):
        return None
    entry["_DesktopId"] = path.name
    return entry


def desktop_app_entries() -> list[dict[str, str]]:
    global DESKTOP_ENTRY_CACHE
    if DESKTOP_ENTRY_CACHE is not None:
        return DESKTOP_ENTRY_CACHE
    entries: list[dict[str, str]] = []
    for desktop_path in desktop_files():
        entry = read_desktop_entry(desktop_path)
        if entry:
            entries.append(entry)
    DESKTOP_ENTRY_CACHE = entries
    return entries


def cached_desktop_icon(widget: QWidget, icon_name: str) -> QIcon:
    key = icon_name.strip()
    if not key:
        return menu_icon(widget, "application-x-executable", QStyle.StandardPixmap.SP_FileIcon)
    cached = DESKTOP_ICON_CACHE.get(key)
    if cached is not None:
        return cached
    icon_path = Path(key).expanduser()
    if icon_path.is_file():
        icon = QIcon(str(icon_path))
    else:
        icon = QIcon.fromTheme(key)
    if icon.isNull():
        icon = menu_icon(widget, "application-x-executable", QStyle.StandardPixmap.SP_FileIcon)
    DESKTOP_ICON_CACHE[key] = icon
    return icon


def mime_apps_for(path: Path, limit: int = 12) -> list[tuple[str, str, str, str]]:
    mime = file_mime_type(path)
    matches: list[tuple[str, str, str, str]] = []
    seen: set[str] = set()
    for entry in desktop_app_entries():
        name = entry["Name"]
        if name in seen:
            continue
        exec_line = entry["Exec"]
        mimes = {value for value in entry.get("MimeType", "").split(";") if value}
        if not mime or mime not in mimes:
            continue
        matches.append((name, exec_line, entry.get("Icon", ""), entry.get("_DesktopId", "")))
        seen.add(name)
        if len(matches) >= limit:
            break
    return matches


def default_app_for_mime(mime: str) -> str:
    if not mime or not shutil.which("xdg-mime"):
        return ""
    try:
        result = subprocess.run(
            ["xdg-mime", "query", "default", mime],
            check=False,
            capture_output=True,
            text=True,
            timeout=2,
        )
    except (OSError, subprocess.SubprocessError):
        return ""
    return result.stdout.strip() if result.returncode == 0 else ""


def set_default_app_for_mime(mime: str, desktop_id: str) -> tuple[bool, str]:
    if not shutil.which("xdg-mime"):
        return False, "xdg-mime was not found."
    try:
        result = subprocess.run(
            ["xdg-mime", "default", desktop_id, mime],
            check=False,
            capture_output=True,
            text=True,
            timeout=4,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        return False, str(exc)
    if result.returncode != 0:
        return False, (result.stderr or result.stdout or "xdg-mime failed.").strip()
    return True, ""


def desktop_exec_command(exec_line: str, paths: list[Path]) -> list[str]:
    parts = shlex.split(exec_line)
    path_args = [str(path) for path in paths]
    url_args = [QUrl.fromLocalFile(str(path)).toString() for path in paths]
    command: list[str] = []
    used_placeholder = False
    for part in parts:
        if part in {"%f", "%u"}:
            command.append(path_args[0] if part == "%f" else url_args[0])
            used_placeholder = True
        elif part in {"%F", "%U"}:
            command.extend(path_args if part == "%F" else url_args)
            used_placeholder = True
        elif part in {"%i", "%c", "%k"}:
            used_placeholder = True
            continue
        else:
            command.append(part.replace("%f", path_args[0]).replace("%u", url_args[0]))
    if not used_placeholder:
        command.extend(path_args)
    return command


def unique_destination(directory: Path, name: str) -> Path:
    candidate = directory / name
    if not candidate.exists():
        return candidate
    stem = candidate.stem
    suffix = candidate.suffix
    for number in range(1, 10000):
        next_candidate = directory / f"{stem} copy {number}{suffix}"
        if not next_candidate.exists():
            return next_candidate
    raise FileExistsError(f"Could not create a unique name for {name}")


def archive_suffix(path: Path) -> str:
    name = path.name.lower()
    for suffix in sorted(ARCHIVE_EXTENSIONS, key=len, reverse=True):
        if name.endswith(suffix):
            return suffix
    return ""


def archive_base_name(path: Path) -> str:
    suffix = archive_suffix(path)
    return path.name[: -len(suffix)] if suffix else path.stem


def is_archive(path: Path) -> bool:
    return bool(archive_suffix(path))


def same_path(left: Path, right: Path) -> bool:
    try:
        return left.resolve() == right.resolve()
    except OSError:
        return left == right


def remove_existing(path: Path) -> None:
    if path.is_dir() and not path.is_symlink():
        shutil.rmtree(path)
    else:
        path.unlink()


def choose_existing_destination(parent: QWidget, source: Path, destination: Path) -> Path | None:
    if not destination.exists():
        return destination

    box = QMessageBox(parent)
    box.setIcon(QMessageBox.Icon.Warning)
    box.setWindowTitle("File Already Exists")
    box.setText(f'"{destination.name}" already exists.')
    box.setInformativeText("Choose a new name, replace the existing item, or cancel.")
    rename_button = box.addButton("Rename", QMessageBox.ButtonRole.AcceptRole)
    replace_button = box.addButton("Replace", QMessageBox.ButtonRole.DestructiveRole)
    cancel_button = box.addButton("Cancel", QMessageBox.ButtonRole.RejectRole)
    if same_path(source, destination):
        replace_button.setEnabled(False)
    box.setDefaultButton(rename_button)
    box.exec()

    clicked = box.clickedButton()
    if clicked == cancel_button:
        return None
    if clicked == replace_button:
        if same_path(source, destination):
            return None
        remove_existing(destination)
        return destination

    suggested = unique_destination(destination.parent, source.name).name
    while True:
        name, ok = get_name(parent, "Rename Copy", "New name:", suggested)
        if not ok:
            return None
        name = name.strip()
        if not name:
            QMessageBox.warning(parent, "Invalid Name", "Enter a file name.")
            continue
        renamed_destination = destination.parent / name
        if same_path(source, renamed_destination):
            QMessageBox.warning(parent, "Invalid Name", "Choose a different name.")
            continue
        if renamed_destination.exists():
            destination = renamed_destination
            suggested = unique_destination(destination.parent, destination.name).name
            box = QMessageBox(parent)
            box.setIcon(QMessageBox.Icon.Warning)
            box.setWindowTitle("File Already Exists")
            box.setText(f'"{destination.name}" already exists.')
            box.setInformativeText("Choose another name, replace the existing item, or cancel.")
            rename_button = box.addButton("Rename", QMessageBox.ButtonRole.AcceptRole)
            replace_button = box.addButton("Replace", QMessageBox.ButtonRole.DestructiveRole)
            cancel_button = box.addButton("Cancel", QMessageBox.ButtonRole.RejectRole)
            if same_path(source, destination):
                replace_button.setEnabled(False)
            box.setDefaultButton(rename_button)
            box.exec()
            clicked = box.clickedButton()
            if clicked == cancel_button:
                return None
            if clicked == replace_button:
                if same_path(source, destination):
                    return None
                remove_existing(destination)
                return destination
            continue
        return renamed_destination


def copy_path(src: Path, dst: Path) -> None:
    if src.is_dir() and not src.is_symlink():
        shutil.copytree(src, dst)
    else:
        shutil.copy2(src, dst)


def add_to_zip(zip_file: zipfile.ZipFile, path: Path, arcname: Path) -> None:
    if path.is_dir() and not path.is_symlink():
        for child in path.iterdir():
            add_to_zip(zip_file, child, arcname / child.name)
    else:
        zip_file.write(path, arcname)


def create_zip_archive(paths: list[Path], destination: Path) -> None:
    with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as zip_file:
        for path in paths:
            add_to_zip(zip_file, path, Path(path.name))


def extract_archive(path: Path, destination: Path) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    root = destination.resolve()

    def ensure_safe(member_name: str) -> None:
        target = (destination / member_name).resolve()
        if target != root and root not in target.parents:
            raise ValueError(f"Archive member escapes destination: {member_name}")

    suffix = archive_suffix(path)
    if suffix == ".zip":
        with zipfile.ZipFile(path) as archive:
            for member in archive.namelist():
                ensure_safe(member)
            archive.extractall(destination)
        return
    if suffix:
        with tarfile.open(path) as archive:
            for member in archive.getmembers():
                ensure_safe(member.name)
            archive.extractall(destination)
        return
    raise ValueError(f"Unsupported archive: {path}")


def copy_size(path: Path) -> int:
    if path.is_dir() and not path.is_symlink():
        total = 0
        for root, _dirs, filenames in os.walk(path):
            for filename in filenames:
                try:
                    total += (Path(root) / filename).stat().st_size
                except OSError:
                    pass
        return total
    try:
        return path.stat().st_size
    except OSError:
        return 0


def copy_file_with_progress(src: Path, dst: Path, progress: QProgressDialog, state: dict[str, int]) -> None:
    progress.setLabelText(f"Copying {src.name}")
    QApplication.processEvents()
    if progress.wasCanceled():
        raise InterruptedError

    dst.parent.mkdir(parents=True, exist_ok=True)
    if src.is_symlink():
        shutil.copy2(src, dst, follow_symlinks=False)
        state["done"] += 1
        progress.setValue(min(progress.maximum(), state["done"]))
        QApplication.processEvents()
        return

    with src.open("rb") as reader, dst.open("wb") as writer:
        while True:
            chunk = reader.read(1024 * 1024)
            if not chunk:
                break
            writer.write(chunk)
            state["done"] += max(1, len(chunk) // (64 * 1024))
            progress.setValue(min(progress.maximum(), state["done"]))
            QApplication.processEvents()
            if progress.wasCanceled():
                raise InterruptedError
    shutil.copystat(src, dst, follow_symlinks=False)


def copy_path_with_progress(src: Path, dst: Path, progress: QProgressDialog, state: dict[str, int]) -> None:
    if src.is_dir() and not src.is_symlink():
        dst.mkdir(parents=True)
        for root, dirs, filenames in os.walk(src):
            root_path = Path(root)
            relative_root = root_path.relative_to(src)
            target_root = dst / relative_root
            target_root.mkdir(parents=True, exist_ok=True)
            for dirname in dirs:
                (target_root / dirname).mkdir()
            for filename in filenames:
                copy_file_with_progress(root_path / filename, target_root / filename, progress, state)
        try:
            shutil.copystat(src, dst, follow_symlinks=False)
        except OSError:
            pass
    else:
        copy_file_with_progress(src, dst, progress, state)


class FileOperationWorker(QObject):
    progress = Signal(int, int, str, object)
    completed = Signal(str, object)
    failed = Signal(str, object)
    canceled = Signal(str, object)

    def __init__(self, operation: str, targets: list[tuple[Path, Path]]) -> None:
        super().__init__()
        self.operation = operation
        self.targets = targets
        self.cancel_requested = False

    @Slot()
    def cancel(self) -> None:
        self.cancel_requested = True

    @Slot()
    def run(self) -> None:
        completed: list[tuple[Path, Path]] = []
        try:
            total_bytes = sum(copy_size(source) for source, _target in self.targets)
            total_units = max(1, (total_bytes + (64 * 1024 - 1)) // (64 * 1024))
            state = {"done": 0, "done_bytes": 0, "total": total_units, "total_bytes": total_bytes, "started_at": time.monotonic()}
            self.progress.emit(0, total_units, self._preparing_label(), 0.0)
            for source, target in self.targets:
                self._check_cancel()
                if self.operation == "copy":
                    self._copy_path(source, target, state)
                    completed.append((target, Path()))
                elif self.operation == "move":
                    self._move_path(source, target, state)
                    completed.append((target, source))
                else:
                    raise ValueError(f"Unsupported operation: {self.operation}")
            self.progress.emit(total_units, total_units, self._done_label(), self._speed_bytes_per_second(state))
            self.completed.emit(self.operation, completed)
        except InterruptedError:
            self.canceled.emit(self.operation, completed)
        except Exception as exc:
            self.failed.emit(str(exc), completed)

    def _preparing_label(self) -> str:
        return "Preparing copy..." if self.operation == "copy" else "Preparing move..."

    def _done_label(self) -> str:
        return "Copy complete" if self.operation == "copy" else "Move complete"

    def _check_cancel(self) -> None:
        if self.cancel_requested:
            raise InterruptedError

    def _speed_bytes_per_second(self, state: dict[str, int | float]) -> float:
        elapsed = max(0.001, time.monotonic() - float(state["started_at"]))
        return float(state["done_bytes"]) / elapsed

    def _emit_progress(self, state: dict[str, int | float], label: str) -> None:
        self.progress.emit(
            min(int(state["total"]), int(state["done"])),
            int(state["total"]),
            label,
            self._speed_bytes_per_second(state),
        )

    def _copy_file(self, source: Path, target: Path, state: dict[str, int | float]) -> None:
        self._check_cancel()
        target.parent.mkdir(parents=True, exist_ok=True)
        self._emit_progress(state, f"Copying {source.name}")
        if source.is_symlink():
            shutil.copy2(source, target, follow_symlinks=False)
            state["done"] += 1
            try:
                state["done_bytes"] += source.lstat().st_size
            except OSError:
                pass
            self._emit_progress(state, f"Copied {source.name}")
            return
        with source.open("rb") as reader, target.open("wb") as writer:
            while True:
                self._check_cancel()
                chunk = reader.read(1024 * 1024)
                if not chunk:
                    break
                writer.write(chunk)
                state["done"] += max(1, len(chunk) // (64 * 1024))
                state["done_bytes"] += len(chunk)
                self._emit_progress(state, f"Copying {source.name}")
        shutil.copystat(source, target, follow_symlinks=False)

    def _copy_path(self, source: Path, target: Path, state: dict[str, int | float]) -> None:
        self._check_cancel()
        if source.is_dir() and not source.is_symlink():
            target.mkdir(parents=True, exist_ok=True)
            for root, dirs, filenames in os.walk(source):
                self._check_cancel()
                root_path = Path(root)
                relative_root = root_path.relative_to(source)
                target_root = target / relative_root
                target_root.mkdir(parents=True, exist_ok=True)
                for dirname in dirs:
                    self._check_cancel()
                    (target_root / dirname).mkdir(exist_ok=True)
                for filename in filenames:
                    self._copy_file(root_path / filename, target_root / filename, state)
            try:
                shutil.copystat(source, target, follow_symlinks=False)
            except OSError:
                pass
            return
        self._copy_file(source, target, state)

    def _move_path(self, source: Path, target: Path, state: dict[str, int | float]) -> None:
        self._check_cancel()
        self._emit_progress(state, f"Moving {source.name}")
        try:
            source_size = copy_size(source)
            source.rename(target)
            state["done"] = min(state["total"], state["done"] + max(1, copy_size(target) // (64 * 1024)))
            state["done_bytes"] += source_size
            self._emit_progress(state, f"Moved {source.name}")
            return
        except OSError:
            pass
        self._copy_path(source, target, state)
        self._check_cancel()
        remove_existing(source)
        self._emit_progress(state, f"Moved {source.name}")


class TerminalLaunchSignals(QObject):
    failed = Signal(str)


TERMINAL_SIGNALS = TerminalLaunchSignals()


def wait_for_process(process: subprocess.Popen) -> None:
    try:
        process.wait()
    except OSError:
        pass


def reap_when_finished(process: subprocess.Popen) -> None:
    waiter = threading.Thread(target=wait_for_process, args=(process,), daemon=True)
    waiter.start()


class TerminalLaunchJob(QRunnable):
    def __init__(self, command: list[str], cwd: Path, signals: TerminalLaunchSignals) -> None:
        super().__init__()
        self.command = command
        self.cwd = cwd
        self.signals = signals

    def run(self) -> None:
        try:
            process = subprocess.Popen(
                self.command,
                cwd=str(self.cwd),
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
                close_fds=True,
            )
        except OSError as exc:
            self.signals.failed.emit(f"{' '.join(self.command)}\n\n{exc}")
            return
        wait_for_process(process)


def finish_visible_progress(progress: QProgressDialog, value: int, started_at: float, minimum_seconds: float = 0.65) -> None:
    progress.setValue(value)
    QApplication.processEvents()
    deadline = started_at + minimum_seconds
    while time.monotonic() < deadline:
        QApplication.processEvents()
        time.sleep(0.02)
    progress.close()


def widen_progress_dialog(progress: QProgressDialog) -> None:
    progress.setMinimumWidth(PROGRESS_DIALOG_WIDTH)
    progress.setMinimumHeight(max(180, progress.sizeHint().height() + 44))
    progress.resize(PROGRESS_DIALOG_WIDTH, max(progress.minimumHeight(), progress.sizeHint().height() + 44))
    for button in progress.findChildren(QPushButton):
        button.setMinimumHeight(max(30, button.sizeHint().height()))


def make_file_drag(source: QWidget, paths: list[Path]) -> QDrag:
    mime = QMimeData()
    mime.setUrls([QUrl.fromLocalFile(str(path)) for path in paths])

    icon = QFileIconProvider().icon(QFileInfo(str(paths[0])))
    pixmap = icon.pixmap(64, 64)
    if pixmap.isNull():
        pixmap = QPixmap(64, 64)
        pixmap.fill(Qt.GlobalColor.transparent)

    drag = QDrag(source)
    drag.setMimeData(mime)
    drag.setPixmap(pixmap)
    drag.setHotSpot(QPoint(12, 12))
    return drag


def move_to_trash(path: Path) -> Path | None:
    source = path.expanduser()
    try:
        source = source.resolve()
    except OSError:
        pass

    trash_root = Path.home() / ".local" / "share" / "Trash"
    files_dir = trash_root / "files"
    info_dir = trash_root / "info"
    try:
        files_dir.mkdir(parents=True, exist_ok=True)
        info_dir.mkdir(parents=True, exist_ok=True)
        target = unique_destination(files_dir, source.name)
        shutil.move(str(source), str(target))
        escaped_path = quote(str(source), safe="/")
        info_path = info_dir / f"{target.name}.trashinfo"
        info_path.write_text(
            "[Trash Info]\n"
            f"Path={escaped_path}\n"
            f"DeletionDate={datetime.now().strftime('%Y-%m-%dT%H:%M:%S')}\n",
            encoding="utf-8",
        )
        return target
    except OSError:
        return None


@dataclass
class PaneState:
    path: Path
    view_mode: str


@dataclass
class UndoAction:
    kind: str
    items: list[tuple[Path, Path]]


@dataclass
class LaunchArgs:
    left_state: PaneState | None
    right_state: PaneState | None
    no_detach: bool


def normalize_view_mode(value: str) -> str:
    return VIEW_ALIASES.get(value.strip().lower(), "")


def parse_args(argv: list[str]) -> LaunchArgs:
    parser = argparse.ArgumentParser(
        prog="fm",
        description="Dual pane file manager.",
        epilog="Example: fm ~/ icon ~/tmp list",
    )
    parser.add_argument(
        "--no-detach",
        action="store_true",
        help="Keep fm attached to the launching terminal.",
    )
    parser.add_argument(
        "pane_args",
        nargs="*",
        metavar="PATH VIEW",
        help="Optional pane path/view pairs. Views: icon, list, details.",
    )
    args = parser.parse_args(argv)
    values = args.pane_args
    if len(values) not in {0, 2, 4}:
        parser.error("use either no arguments, one PATH VIEW pair, or two PATH VIEW pairs")

    states: list[PaneState] = []
    for index in range(0, len(values), 2):
        path_value = values[index]
        mode = normalize_view_mode(values[index + 1])
        if not mode:
            parser.error(f"unknown view '{values[index + 1]}'; use icon, list, or details")
        states.append(PaneState(Path(path_value).expanduser(), mode))

    left_state = states[0] if len(states) >= 1 else None
    right_state = states[1] if len(states) >= 2 else None
    return LaunchArgs(left_state, right_state, args.no_detach)


def detach_if_terminal(no_detach: bool) -> None:
    if no_detach or os.environ.get("FM_NO_DETACH"):
        return
    if os.environ.get("QT_QPA_PLATFORM") == "offscreen":
        return
    if not hasattr(os, "fork") or not sys.stdin.isatty():
        return

    pid = os.fork()
    if pid:
        raise SystemExit(0)

    os.setsid()
    try:
        devnull = os.open(os.devnull, os.O_RDWR)
        for fd in (0, 1, 2):
            try:
                os.dup2(devnull, fd)
            except OSError:
                pass
        if devnull > 2:
            os.close(devnull)
    except OSError:
        pass


