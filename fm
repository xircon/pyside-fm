    def _on_directory_loaded(self, path: str) -> None:
        if Path(path) == self.current_path():
            self._update_status()

    def _update_navigation(self) -> None:
        self.back_button.setEnabled(self._history_index > 0)
        self.forward_button.setEnabled(self._history_index < len(self._history) - 1)

    def _update_status(self) -> None:
        self._update_preview()
        selected = self.selected_paths()
        if selected:
            total = 0
            for path in selected:
                try:
                    if path.is_file() or path.is_symlink():
                        total += path.stat().st_size
                except OSError:
                    pass
            self.status_label.setText(f"{len(selected)} selected, {readable_size(total)}")
            return

        directory = self.current_path()
        try:
            entries = [entry for entry in directory.iterdir() if entry.name not in {".", ".."}]
        except OSError:
            entries = []
        dirs = sum(1 for entry in entries if entry.is_dir())
        files = len(entries) - dirs
        suffix = f" matching '{self.search_text}'" if self.search_text.strip() else ""
        self.status_label.setText(f"{files} files, {dirs} folders{suffix}")

    def _update_preview(self) -> None:
        if not self.preview_enabled:
            self._clear_preview()
            self.preview_source_path = None
            self.preview_source_pixmap = QPixmap()
            return
        path = self.current_item_path()
        self._show_preview_path(path)

    def _show_preview_path(self, path: Path | None) -> None:
        if not path or not path.is_file():
            self._clear_preview()
            self.preview_source_path = None
            self.preview_source_pixmap = QPixmap()
            return
        if path.suffix.lower() in TEXT_EXTENSIONS or file_mime_type(path).startswith("text/"):
            self._show_text_preview(path)
            return
        if path.suffix.lower() in PDF_EXTENSIONS:
            self._show_pdf_preview(path)
            return
        if path.suffix.lower() not in IMAGE_EXTENSIONS:
            self._clear_preview()
            self.preview_source_path = None
            self.preview_source_pixmap = QPixmap()
            return
        if self.preview_source_path != path:
            self.preview_source_path = path
            self.preview_source_pixmap = QPixmap(str(path))
        if self.preview_source_pixmap.isNull():
            self._clear_preview()
            return
        if self.manual_preview_active:
            self._set_pdf_controls_visible(False)
            self.full_preview_text.setVisible(False)
            self.full_preview_label.setVisible(True)
            self.full_preview_stack.setCurrentWidget(self.full_preview_image)
            self._rescale_full_preview()
            return
        self.preview_text.setVisible(False)
        self.preview_label.setVisible(True)
        self.preview_stack.setCurrentWidget(self.preview_label)
        self._rescale_preview()

    def show_manual_preview(self, path: Path) -> None:
        self.manual_preview_active = True
        self.full_preview_zoom = 1.0
        self.preview_splitter.setSizes([max(1, sum(self.preview_splitter.sizes())), 0])
        self.preview_stack.setVisible(False)
        self.stack.setCurrentWidget(self.full_preview_stack)
        self._show_preview_path(path)
        if self.full_preview_stack.currentWidget() is self.full_preview_text:
            self.full_preview_text.setFocus()
        else:
            self.full_preview_image.setFocus()

    def close_manual_preview(self) -> bool:
        if not self.manual_preview_active:
            return False
        self.manual_preview_active = False
        self.full_preview_label.clear()
        self.full_preview_text.clear()
        self._clear_preview()
        self.preview_source_path = None
        self.preview_source_pixmap = QPixmap()
        self.full_preview_zoom = 1.0
        self.preview_pdf_page = 0
        self.preview_pdf_page_count = 0
        self.stack.setCurrentIndex(VIEW_MODES.index(self.view_combo.currentText()))
        self.set_preview_enabled(self.preview_enabled)
        return True

    def _rescale_preview(self) -> None:
        if self.preview_source_pixmap.isNull() or not self.preview_label.isVisible():
            return
        self.preview_label.setPixmap(
            self.preview_source_pixmap.scaled(
                QSize(max(180, self.preview_label.width() - 12), max(80, self.preview_label.height() - 12)),
                Qt.AspectRatioMode.KeepAspectRatio,
                Qt.TransformationMode.SmoothTransformation,
            )
        )

    def _rescale_full_preview(self) -> None:
        if self.preview_source_pixmap.isNull() or not self.full_preview_label.isVisible():
            return
        viewport = self.full_preview_scroll.viewport().size()
        fit_size = self.preview_source_pixmap.size().scaled(
            QSize(max(240, viewport.width() - 24), max(180, viewport.height() - 24)),
            Qt.AspectRatioMode.KeepAspectRatio,
        )
        scaled_size = QSize(
            max(1, int(fit_size.width() * self.full_preview_zoom)),
            max(1, int(fit_size.height() * self.full_preview_zoom)),
        )
        pixmap = self.preview_source_pixmap.scaled(
            scaled_size,
            Qt.AspectRatioMode.KeepAspectRatio,
            Qt.TransformationMode.SmoothTransformation,
        )
        self.full_preview_label.setPixmap(pixmap)
        self.full_preview_label.setFixedSize(pixmap.size())

    def zoom_full_preview(self, step: int) -> bool:
        if not self.manual_preview_active:
            return False
        if self.full_preview_stack.currentWidget() is self.full_preview_text:
            self.full_preview_text.zoomIn(step)
            return True
        factor = 1.2 if step > 0 else 1 / 1.2
        self.full_preview_zoom = max(0.4, min(4.0, self.full_preview_zoom * factor))
        self._rescale_full_preview()
        return True

    def reset_full_preview_zoom(self) -> None:
        self.full_preview_zoom = 1.0
        self._rescale_full_preview()

    def _show_text_preview(self, path: Path) -> None:
        if self.preview_source_path != path or self.manual_preview_active:
            self.preview_source_path = path
            self.preview_source_pixmap = QPixmap()
            try:
                data = path.read_bytes()[:256 * 1024]
                text = data.decode("utf-8", errors="replace")
                if path.stat().st_size > len(data):
                    text += "\n\n... preview truncated ..."
            except OSError as exc:
                text = str(exc)
            target = self.full_preview_text if self.manual_preview_active else self.preview_text
            target.setPlainText(text)
            target.moveCursor(target.textCursor().MoveOperation.Start)
        if self.manual_preview_active:
            self._set_pdf_controls_visible(False)
            self.full_preview_label.clear()
            self.full_preview_label.setVisible(False)
            self.full_preview_text.setVisible(True)
            self.full_preview_stack.setCurrentWidget(self.full_preview_text)
            return
        self.preview_label.clear()
        self.preview_label.setVisible(False)
        self.preview_text.setVisible(True)
        self.preview_stack.setCurrentWidget(self.preview_text)

    def _show_pdf_preview(self, path: Path) -> None:
        if self.preview_source_path != path:
            self.preview_source_path = path
            self.preview_pdf_page = 0
        self._render_pdf_page(path)
        if self.preview_source_pixmap.isNull():
            self._clear_preview()
            return
        if self.manual_preview_active:
            self._set_pdf_controls_visible(True)
            self.full_preview_text.setVisible(False)
            self.full_preview_label.setVisible(True)
            self.full_preview_stack.setCurrentWidget(self.full_preview_image)
            self._rescale_full_preview()
            return
        self.preview_text.setVisible(False)
        self.preview_label.setVisible(True)
        self.preview_stack.setCurrentWidget(self.preview_label)
        self._rescale_preview()

    def _render_pdf_page(self, path: Path) -> None:
        self.preview_source_pixmap = QPixmap()
        document = QPdfDocument(self)
        if document.load(str(path)) != QPdfDocument.Error.None_ or document.pageCount() <= 0:
            self.preview_pdf_page_count = 0
            return
        self.preview_pdf_page_count = document.pageCount()
        self.preview_pdf_page = max(0, min(self.preview_pdf_page, self.preview_pdf_page_count - 1))
        page_size = document.pagePointSize(self.preview_pdf_page).toSize()
        if page_size.isEmpty():
            page_size = QSize(900, 1200)
        render_size = page_size.scaled(QSize(1600, 2200), Qt.AspectRatioMode.KeepAspectRatio)
        image = document.render(self.preview_pdf_page, render_size)
        if not image.isNull():
            self.preview_source_pixmap = QPixmap.fromImage(image)

    def _set_pdf_controls_visible(self, visible: bool) -> None:
        self.pdf_controls.setVisible(visible and self.manual_preview_active)
        self._update_pdf_controls()

    def _update_pdf_controls(self) -> None:
        total = max(0, self.preview_pdf_page_count)
        current = self.preview_pdf_page + 1 if total else 0
        self.pdf_page_label.setText(f"Page {current} / {total}")
        self.pdf_prev_button.setEnabled(total > 1 and self.preview_pdf_page > 0)
        self.pdf_next_button.setEnabled(total > 1 and self.preview_pdf_page < total - 1)

    def previous_pdf_page(self) -> None:
        if not self.preview_source_path or self.preview_pdf_page <= 0:
            return
        self.preview_pdf_page -= 1
        self._show_pdf_preview(self.preview_source_path)

    def next_pdf_page(self) -> None:
        if not self.preview_source_path or self.preview_pdf_page >= self.preview_pdf_page_count - 1:
            return
        self.preview_pdf_page += 1
        self._show_pdf_preview(self.preview_source_path)

    def _clear_preview(self) -> None:
        self.preview_label.clear()
        self.preview_label.setVisible(False)
        self.preview_text.clear()
        self.preview_text.setVisible(False)
        self.full_preview_label.clear()
        self.full_preview_text.clear()


