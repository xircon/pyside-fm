    def _text_tab(self, html: str) -> QTextEdit:
        text = QTextEdit()
        text.setReadOnly(True)
        text.setHtml(html)
        return text

    def _group_widget(self, title: str, rows: list[tuple[str, str]]) -> QWidget:
        widget = QWidget()
        layout = QVBoxLayout(widget)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(6)

        heading = QLabel(title)
        heading.setStyleSheet("font-weight: 600;")
        layout.addWidget(heading)

        grid = QGridLayout()
        grid.setContentsMargins(0, 0, 0, 0)
        grid.setHorizontalSpacing(18)
        grid.setVerticalSpacing(8)
        grid.setColumnStretch(0, 0)
        grid.setColumnStretch(1, 1)
        for row, (action, keys) in enumerate(rows):
            key_label = QLabel(keys)
            key_label.setMinimumWidth(170)
            key_label.setAlignment(Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignTop)
            key_label.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
            action_label = QLabel(action)
            action_label.setWordWrap(True)
            action_label.setMinimumWidth(360)
            action_label.setAlignment(Qt.AlignmentFlag.AlignLeft | Qt.AlignmentFlag.AlignTop)
            action_label.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
            grid.addWidget(key_label, row, 0)
            grid.addWidget(action_label, row, 1)
        layout.addLayout(grid)
        return widget

    def _fit_to_parent(self) -> None:
        if not self._parent_window:
            self.resize(760, 520)
            return
        parent_rect = self._parent_window.frameGeometry()
        max_width = max(520, parent_rect.width() - 20)
        max_height = max(360, parent_rect.height() - 20)
        self.setMaximumSize(max_width, max_height)
        self.resize(min(860, max_width), min(620, max_height))
        self.move(
            parent_rect.x() + 10 + max(0, (max_width - self.width()) // 2),
            parent_rect.y() + 10 + max(0, (max_height - self.height()) // 2),
        )

    def showEvent(self, event) -> None:
        self._fit_to_parent()
        super().showEvent(event)

    def keyPressEvent(self, event) -> None:
        if event.key() == Qt.Key.Key_Escape:
            self.reject()
            return
        super().keyPressEvent(event)


