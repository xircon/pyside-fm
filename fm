    def _dual_bookmark_row_changed(self, row: int) -> None:
        if self._loading_dual_bookmark:
            return
        previous = self._current_dual_bookmark_row
        if previous >= 0 and previous != row:
            self._sync_dual_bookmark_row(previous)
        self._current_dual_bookmark_row = row
        self._load_dual_bookmark_row(row)

    def _load_dual_bookmark_row(self, row: int) -> None:
        self._loading_dual_bookmark = True
        try:
            item = self.dual_bookmark_list.item(row)
            bookmark = item.data(Qt.ItemDataRole.UserRole) if item else {}
            self.dual_bookmark_name_edit.setText(str(bookmark.get("name", "")) if isinstance(bookmark, dict) else "")
            self.dual_bookmark_left_edit.setText(str(bookmark.get("left", "")) if isinstance(bookmark, dict) else "")
            self.dual_bookmark_right_edit.setText(str(bookmark.get("right", "")) if isinstance(bookmark, dict) else "")
        finally:
            self._loading_dual_bookmark = False

    def _current_dual_bookmark(self) -> dict[str, str]:
        name = self.dual_bookmark_name_edit.text().strip()
        left = self.dual_bookmark_left_edit.text().strip()
        right = self.dual_bookmark_right_edit.text().strip()
        if not name:
            left_name = Path(left).expanduser().name or left
            right_name = Path(right).expanduser().name or right
            name = f"{left_name} / {right_name}".strip(" /")
        return {"name": name, "left": left, "right": right}

    def _dual_bookmark_label(self, bookmark: dict[str, str]) -> str:
        name = bookmark.get("name", "").strip() or "Dual bookmark"
        left = bookmark.get("left", "").strip()
        right = bookmark.get("right", "").strip()
        if left and right:
            return f"{name}: {left} -> {right}"
        return name

    def _append_dual_bookmark(self, bookmark: dict[str, str]) -> None:
        cleaned = {
            "name": str(bookmark.get("name", "")).strip(),
            "left": str(bookmark.get("left", "")).strip(),
            "right": str(bookmark.get("right", "")).strip(),
        }
        item = QListWidgetItem(self._dual_bookmark_label(cleaned))
        item.setData(Qt.ItemDataRole.UserRole, cleaned)
        self.dual_bookmark_list.addItem(item)

    def _sync_dual_bookmark_row(self, row: int) -> None:
        item = self.dual_bookmark_list.item(row)
        if not item:
            return
        bookmark = self._current_dual_bookmark()
        item.setData(Qt.ItemDataRole.UserRole, bookmark)
        item.setText(self._dual_bookmark_label(bookmark))

    def _add_dual_bookmark(self) -> None:
        bookmark = self._current_dual_bookmark()
        if not bookmark["left"] or not bookmark["right"]:
            QMessageBox.warning(self, "Dual Bookmark", "Choose both left and right folders.")
            return
        self._append_dual_bookmark(bookmark)
        row = self.dual_bookmark_list.count() - 1
        self._loading_dual_bookmark = True
        try:
            self.dual_bookmark_list.setCurrentRow(row)
            self._current_dual_bookmark_row = row
        finally:
            self._loading_dual_bookmark = False
        self._load_dual_bookmark_row(row)

    def _update_dual_bookmark(self) -> None:
        row = self.dual_bookmark_list.currentRow()
        if row < 0:
            self._add_dual_bookmark()
            return
        self._sync_dual_bookmark_row(row)

    def _delete_dual_bookmark(self) -> None:
        row = self.dual_bookmark_list.currentRow()
        if row < 0:
            return
        self._loading_dual_bookmark = True
        try:
            self.dual_bookmark_list.takeItem(row)
            if self.dual_bookmark_list.count():
                self._current_dual_bookmark_row = min(row, self.dual_bookmark_list.count() - 1)
                self.dual_bookmark_list.setCurrentRow(self._current_dual_bookmark_row)
            else:
                self._current_dual_bookmark_row = -1
        finally:
            self._loading_dual_bookmark = False
        self._load_dual_bookmark_row(self._current_dual_bookmark_row)

    def _browse_dual_bookmark_path(self, side: str) -> None:
        current_text = self.dual_bookmark_left_edit.text() if side == "left" else self.dual_bookmark_right_edit.text()
        start = str(Path(current_text or "~").expanduser())
        chosen = QFileDialog.getExistingDirectory(self, "Choose Folder", start)
        if not chosen:
            return
        display = display_path_label(Path(chosen))
        if side == "left":
            self.dual_bookmark_left_edit.setText(display)
        else:
            self.dual_bookmark_right_edit.setText(display)

    def theme(self) -> str:
        return self.theme_combo.currentText()

    def icon_layout(self) -> str:
        return self.icon_layout_combo.currentText()

    def terminal_command(self) -> str:
        return self.terminal_command_edit.text().strip() or DEFAULT_TERMINAL_COMMAND

    def terminal_args(self) -> str:
        return self.terminal_args_edit.text().strip()

    def user_buttons(self) -> list[dict[str, str]]:
        buttons = []
        for label_edit, symbol_edit, command_edit in self.button_edits:
            buttons.append(
                {
                    "label": label_edit.text().strip(),
                    "symbol": symbol_edit.text().strip(),
                    "command": command_edit.text().strip(),
                }
            )
        return buttons

    def dual_bookmarks(self) -> list[dict[str, str]]:
        row = self.dual_bookmark_list.currentRow()
        if row >= 0:
            self._sync_dual_bookmark_row(row)
        bookmarks: list[dict[str, str]] = []
        for index in range(self.dual_bookmark_list.count()):
            item = self.dual_bookmark_list.item(index)
            bookmark = item.data(Qt.ItemDataRole.UserRole)
            if not isinstance(bookmark, dict):
                continue
            cleaned = {
                "name": str(bookmark.get("name", "")).strip(),
                "left": str(bookmark.get("left", "")).strip(),
                "right": str(bookmark.get("right", "")).strip(),
            }
            if cleaned["left"] and cleaned["right"]:
                bookmarks.append(cleaned)
        return bookmarks


