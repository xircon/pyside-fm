        update_button.clicked.connect(lambda _checked=False: self._update_dual_bookmark())
        delete_button.clicked.connect(lambda _checked=False: self._delete_dual_bookmark())
        action_row.addWidget(add_button)
        action_row.addWidget(update_button)
        action_row.addWidget(delete_button)
