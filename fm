            subtitle = str(paths[0].parent if paths[0].parent != paths[0] else paths[0])
        else:
            icon = self.style().standardIcon(QStyle.StandardPixmap.SP_FileDialogDetailedView)
            title = f"{len(paths)} items"
            subtitle = "Multiple selection"
        icon_label.setPixmap(icon.pixmap(48, 48))

