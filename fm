    def set_preview_enabled(self, enabled: bool) -> None:
        sizes = self.preview_splitter.sizes()
        if not enabled and len(sizes) > 1 and sizes[1] > 0:
            self.last_preview_height = sizes[1]
        self.preview_enabled = enabled
        self.preview_stack.setVisible(enabled)
        if enabled:
            total = max(sum(sizes), self.preview_splitter.height(), self.last_preview_height + 120)
            preview_height = max(80, min(self.last_preview_height, total - 80))
            self.preview_splitter.setSizes([max(80, total - preview_height), preview_height])
            self._update_preview()
        else:
            self._clear_preview()
            total = max(sum(sizes), self.preview_splitter.height(), 1)
            self.preview_splitter.setSizes([total, 0])

