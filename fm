class ThumbnailSignals(QObject):
    loaded = Signal(str, object, object, QImage)


THUMBNAIL_SIGNALS = ThumbnailSignals()


class ThumbnailJob(QRunnable):
    def __init__(self, path: Path, mtime_ns: int, size: int, signals: ThumbnailSignals) -> None:
        super().__init__()
        self.path = path
        self.mtime_ns = mtime_ns
        self.size = size
        self.signals = signals

    def run(self) -> None:
        reader = QImageReader(str(self.path))
        reader.setAutoTransform(True)
        reader.setScaledSize(QSize(128, 128))
        image = reader.read()
        if not image.isNull():
            self.signals.loaded.emit(str(self.path), self.mtime_ns, self.size, image)


class FileSystemNoDropModel(QFileSystemModel):
    def __init__(self, parent: QObject | None = None) -> None:
        super().__init__(parent)
        self._tagged_paths: set[Path] = set()
        self._tagged_background = QBrush(QColor("#2b1268"))
        self._tagged_foreground = QBrush(QColor("#ffffff"))
        self._thumbnail_cache: dict[tuple[str, int, int], QIcon] = {}
        self._thumbnail_pending: set[tuple[str, int, int]] = set()
        self._thumbnail_failed: set[tuple[str, int, int]] = set()
        self._folder_emblems: dict[str, str] = {}
        self._emblem_icon_cache: dict[tuple[str, str], QIcon] = {}
        self._thumbnail_pool = QThreadPool(self)
        self._thumbnail_pool.setMaxThreadCount(2)
        self._thumbnail_signals = THUMBNAIL_SIGNALS
        self._thumbnail_signals.loaded.connect(self._thumbnail_loaded)

    def flags(self, index: QModelIndex) -> Qt.ItemFlag:
        return super().flags(index) & ~Qt.ItemFlag.ItemIsDropEnabled

    def supportedDropActions(self) -> Qt.DropAction:
        return Qt.DropAction.IgnoreAction

    def data(self, index: QModelIndex, role: int = Qt.ItemDataRole.DisplayRole):
        if role == Qt.ItemDataRole.BackgroundRole and Path(self.filePath(index)) in self._tagged_paths:
            return self._tagged_background
        if role == Qt.ItemDataRole.ForegroundRole and Path(self.filePath(index)) in self._tagged_paths:
            return self._tagged_foreground
        if role == Qt.ItemDataRole.DecorationRole and index.column() == 0:
            path = Path(self.filePath(index))
            emblem_key = self._folder_emblems.get(str(path))
            if emblem_key and path.is_dir():
                base_icon = super().data(index, role)
                if isinstance(base_icon, QIcon):
                    cache_key = (str(path), emblem_key)
                    cached = self._emblem_icon_cache.get(cache_key)
                    if cached:
                        return cached
                    icon = folder_icon_with_emblem(base_icon, emblem_key)
                    self._emblem_icon_cache[cache_key] = icon
                    if len(self._emblem_icon_cache) > 512:
                        self._emblem_icon_cache.clear()
                    return icon
            if path.suffix.lower() in IMAGE_EXTENSIONS and path.is_file():
                icon = self._thumbnail_icon(path)
                if icon:
                    return icon
        return super().data(index, role)

    def set_folder_emblems(self, emblems: dict[str, str]) -> None:
        old_paths = set(self._folder_emblems)
        self._folder_emblems = dict(emblems)
        self._emblem_icon_cache.clear()
        for path_text in old_paths | set(self._folder_emblems):
            index = self.index(path_text)
            if index.isValid():
                self.dataChanged.emit(index, index, [Qt.ItemDataRole.DecorationRole])

    def set_tagged_paths(self, paths: set[Path]) -> None:
        old_paths = set(self._tagged_paths)
        self._tagged_paths = set(paths)
        for path in old_paths | self._tagged_paths:
            index = self.index(str(path))
            if index.isValid():
                last_column = max(0, self.columnCount(index.parent()) - 1)
                last_index = index.siblingAtColumn(last_column)
                self.dataChanged.emit(
                    index.siblingAtColumn(0),
                    last_index,
                    [Qt.ItemDataRole.BackgroundRole, Qt.ItemDataRole.ForegroundRole],
                )

    def _thumbnail_icon(self, path: Path) -> QIcon | None:
        try:
            stat = path.stat()
        except OSError:
            return None
        key = (str(path), stat.st_mtime_ns, stat.st_size)
        cached = self._thumbnail_cache.get(key)
        if cached:
            return cached
        if key not in self._thumbnail_pending and key not in self._thumbnail_failed:
            self._thumbnail_pending.add(key)
            self._thumbnail_pool.start(ThumbnailJob(path, stat.st_mtime_ns, stat.st_size, self._thumbnail_signals))
        return None

    @Slot(str, object, object, QImage)
    def _thumbnail_loaded(self, path: str, mtime_ns: int, size: int, image: QImage) -> None:
        key = (path, mtime_ns, size)
        if key not in self._thumbnail_pending:
            return
        self._thumbnail_pending.discard(key)
        if image.isNull():
            self._thumbnail_failed.add(key)
            return
        pixmap = QPixmap.fromImage(image).scaled(
            QSize(96, 96),
            Qt.AspectRatioMode.KeepAspectRatio,
            Qt.TransformationMode.SmoothTransformation,
        )
        self._thumbnail_cache[key] = QIcon(pixmap)
        if len(self._thumbnail_cache) > 512:
            self._thumbnail_cache.clear()
        index = self.index(path)
        if index.isValid():
            self.dataChanged.emit(index, index, [Qt.ItemDataRole.DecorationRole])


