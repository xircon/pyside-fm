        return bool(pane and pane.zoom_full_preview(step))

    def handle_manual_preview_key(self, event) -> bool:
        if event.modifiers() != Qt.KeyboardModifier.NoModifier:
            return False
        next_keys = {Qt.Key.Key_PageDown, Qt.Key.Key_Right, Qt.Key.Key_Down}
        previous_keys = {Qt.Key.Key_PageUp, Qt.Key.Key_Left, Qt.Key.Key_Up}
        if event.key() not in next_keys | previous_keys:
            return False
        pane = self.left if self.left.manual_preview_active else self.right if self.right.manual_preview_active else None
        if not pane or pane.preview_pdf_page_count <= 1:
            return False
        if event.key() in next_keys:
            pane.next_pdf_page()
        else:
            pane.previous_pdf_page()
        return True

