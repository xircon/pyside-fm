        buttons: list[dict[str, str]] = []
        if isinstance(raw_buttons, list):
            for item in raw_buttons[:USER_BUTTON_COUNT]:
                if isinstance(item, dict):
                    buttons.append(
                        {
                            "label": str(item.get("label", "")),
                            "symbol": str(item.get("symbol", "")),
                            "command": str(item.get("command", "")),
                        }
                    )
        while len(buttons) < USER_BUTTON_COUNT:
            buttons.append({"label": "", "symbol": "", "command": ""})
        return buttons

    def _load_dual_bookmarks(self) -> list[dict[str, str]]:
        try:
            raw_bookmarks = json.loads(str(self.settings.value("dualBookmarksJson", "[]")))
        except json.JSONDecodeError:
            raw_bookmarks = []
        bookmarks: list[dict[str, str]] = []
        if isinstance(raw_bookmarks, list):
            for item in raw_bookmarks:
                if not isinstance(item, dict):
                    continue
                bookmark = {
                    "name": str(item.get("name", "")).strip(),
                    "left": str(item.get("left", "")).strip(),
                    "right": str(item.get("right", "")).strip(),
                }
                if bookmark["left"] and bookmark["right"]:
                    bookmarks.append(bookmark)
        return bookmarks

    def _load_folder_emblems(self) -> dict[str, str]:
        try:
            raw_emblems = json.loads(str(self.settings.value("folderEmblemsJson", "{}")))
        except json.JSONDecodeError:
            raw_emblems = {}
        valid_keys = {key for key, _label, _glyph, _color in FOLDER_EMBLEMS}
        emblems: dict[str, str] = {}
        if isinstance(raw_emblems, dict):
            for path_text, emblem in raw_emblems.items():
                path = str(path_text).strip()
                key = str(emblem).strip()
                if path and key in valid_keys:
                    emblems[path] = key
        return emblems

    def _dual_bookmark_combo_label(self, bookmark: dict[str, str]) -> str:
        name = bookmark.get("name", "").strip()
        if name:
            return name
        left = Path(bookmark.get("left", "")).expanduser().name or bookmark.get("left", "")
        right = Path(bookmark.get("right", "")).expanduser().name or bookmark.get("right", "")
        return f"{left} / {right}".strip(" /") or "Dual bookmark"

    def _populate_dual_bookmark_combo(self) -> None:
        combo = getattr(self, "dual_bookmark_combo", None)
        if not isinstance(combo, QComboBox):
            return
        combo.blockSignals(True)
        try:
            combo.clear()
            combo.addItem("Dual Bookmarks", None)
            for bookmark in self.dual_bookmarks:
                combo.addItem(self._dual_bookmark_combo_label(bookmark), bookmark)
            combo.setEnabled(bool(self.dual_bookmarks))
            combo.setCurrentIndex(0)
        finally:
            combo.blockSignals(False)

    def apply_dual_bookmark(self, index: int) -> None:
        combo = getattr(self, "dual_bookmark_combo", None)
        if not isinstance(combo, QComboBox) or index <= 0:
            return
        bookmark = combo.itemData(index)
        combo.setCurrentIndex(0)
        if not isinstance(bookmark, dict):
            return
        left_path = Path(str(bookmark.get("left", ""))).expanduser()
        right_path = Path(str(bookmark.get("right", ""))).expanduser()
        self.clear_pane_zoom()
        self.left.set_path(left_path)
        self.right.set_path(right_path)

    def folder_emblem_for(self, path: Path) -> str:
        return self.folder_emblems.get(str(self._normalized_emblem_path(path)), "")

    def set_folder_emblem(self, path: Path, emblem: str) -> None:
        normalized = self._normalized_emblem_path(path)
        key = str(emblem).strip()
        valid_keys = {value for value, _label, _glyph, _color in FOLDER_EMBLEMS}
        if key and key not in valid_keys:
            return
        if key:
            self.folder_emblems[str(normalized)] = key
        else:
            self.folder_emblems.pop(str(normalized), None)
        self.left.set_folder_emblems(self.folder_emblems)
        self.right.set_folder_emblems(self.folder_emblems)
        self.settings.setValue("folderEmblemsJson", json.dumps(self.folder_emblems))
        self.settings.sync()

    def _normalized_emblem_path(self, path: Path) -> Path:
        expanded = path.expanduser()
        try:
            return expanded.resolve()
        except OSError:
            return expanded

    def _populate_user_toolbar_buttons(self) -> None:
        if not hasattr(self, "main_toolbar"):
            return
        for action in self.user_button_actions:
            self.main_toolbar.removeAction(action)
        self.user_button_actions.clear()
        for index, button in enumerate(self.user_buttons):
            command = button.get("command", "").strip()
            if not command:
                continue
            label = button.get("label", "").strip() or f"Button {index + 1}"
            symbol = button.get("symbol", "").strip()
            action = QAction(label, self)
            if symbol.startswith("icon:"):
                icon_name = symbol.partition(":")[2].strip()
                icon = QIcon.fromTheme(icon_name)
                if not icon.isNull():
                    action.setIcon(icon)
            elif symbol:
                icon_path = Path(symbol).expanduser()
                if icon_path.exists() and icon_path.is_file():
                    icon = QIcon(str(icon_path))
                    if not icon.isNull():
                        action.setIcon(icon)
                    action.setToolTip(label)
                else:
                    action.setText(symbol)
                    action.setToolTip(label)
            action.triggered.connect(lambda _checked=False, row=index, window=self: window.run_user_button(row))
            anchor = getattr(self, "user_button_anchor", None)
            if isinstance(anchor, QAction):
                self.main_toolbar.insertAction(anchor, action)
            else:
                self.main_toolbar.addAction(action)
            self.user_button_actions.append(action)

    def terminal_command_line(self) -> list[str]:
        command = self.terminal_command.strip() or DEFAULT_TERMINAL_COMMAND
        args = shlex.split(self.terminal_args) if self.terminal_args.strip() else []
        executable = shutil.which(command) or command
        return [executable, *args]

    def launch_terminal_at(self, path: Path) -> None:
        try:
            command = self.terminal_command_line()
        except ValueError as exc:
            QMessageBox.warning(self, "Terminal Failed", str(exc))
            return
        QThreadPool.globalInstance().start(TerminalLaunchJob(command, path, TERMINAL_SIGNALS))

    @Slot(str)
    def _terminal_launch_failed(self, message: str) -> None:
        QMessageBox.warning(self, "Terminal Failed", message)

    def run_user_button(self, index: int) -> None:
        if index < 0 or index >= len(self.user_buttons):
            return
        command_text = self.user_buttons[index].get("command", "").strip()
        if not command_text:
            return
        try:
            parts = shlex.split(command_text)
        except ValueError as exc:
            QMessageBox.warning(self, "Command Failed", str(exc))
            return
        if not parts:
            return
        pane = self.active_pane
        selected = " ".join(str(path) for path in pane.operation_paths())
        replacements = {
            "path": str(pane.current_path()),
            "left": str(self.left.current_path()),
            "right": str(self.right.current_path()),
            "selected": selected,
        }
        try:
            command = [part.format(**replacements) for part in parts]
        except KeyError as exc:
            QMessageBox.warning(self, "Command Failed", f"Unknown placeholder: {exc}")
            return
        command[0] = shutil.which(command[0]) or command[0]
        try:
            reap_when_finished(subprocess.Popen(command, cwd=str(pane.current_path())))
        except OSError as exc:
            QMessageBox.warning(self, "Command Failed", f"{command_text}\n\n{exc}")

