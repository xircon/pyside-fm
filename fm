    def current_mode(self) -> str:
        return self.tabs.tabText(self.tabs.currentIndex())

    def set_mode(self, mode: str) -> None:
        for index in range(self.tabs.count()):
            if self.tabs.tabText(index) == mode:
                self.tabs.setCurrentIndex(index)
                return

    def select_home_in_tree(self) -> None:
        index = self.tree_model.index(str(Path.home()))
        if not index.isValid():
            return
        parent = index.parent()
        while parent.isValid():
            self.tree.expand(parent)
            parent = parent.parent()
        self.tree.setCurrentIndex(index)
        self.tree.selectionModel().select(
            index,
            QItemSelectionModel.SelectionFlag.ClearAndSelect | QItemSelectionModel.SelectionFlag.Rows,
        )
        self.tree.scrollTo(index, QAbstractItemView.ScrollHint.PositionAtCenter)

    def _apply_tree_filter(self) -> None:
        flags = QDir.Filter.AllDirs | QDir.Filter.NoDotAndDotDot
        if self.show_hidden:
            flags |= QDir.Filter.Hidden
        self.tree_model.setFilter(flags)

    def set_show_hidden(self, show_hidden: bool) -> None:
        self.show_hidden = show_hidden
        self._apply_tree_filter()

    def set_favorites(self, favorites: list[Path], names: dict[str, str] | None = None) -> None:
        seen: set[Path] = set()
        self.favorites = []
        self.favorite_names = {}
        for path in favorites:
            try:
                resolved = path.expanduser().resolve()
            except OSError:
                resolved = path.expanduser()
            if resolved.exists() and resolved not in seen:
                seen.add(resolved)
                self.favorites.append(resolved)
                if names and str(resolved) in names:
                    self.favorite_names[resolved] = names[str(resolved)]
        self._populate_shortcuts()

    def set_recent_paths(self, paths: list[Path]) -> None:
        self.recent_paths = [path for path in paths if path.exists() and path.is_dir()]
        self._populate_shortcuts()

    def add_favorite(self, path: Path) -> None:
        try:
            favorite = path.expanduser().resolve()
        except OSError:
            favorite = path.expanduser()
        if favorite not in self.favorites:
            self.favorites.append(favorite)
            self._populate_shortcuts()
            self._favorites_changed()

    def remove_favorite(self, path: Path) -> None:
        self.favorites = [favorite for favorite in self.favorites if favorite != path]
        self.favorite_names.pop(path, None)
        self._populate_shortcuts()
        self._favorites_changed()

    def remove_recent(self, path: Path) -> None:
        self.recent_paths = [recent for recent in self.recent_paths if recent != path]
        self._populate_shortcuts()
        self._recent_changed()

    def clear_recent(self) -> None:
        self.recent_paths = []
        self._populate_shortcuts()
        self._recent_changed()

    def rename_favorite(self, path: Path) -> None:
        current = self.favorite_names.get(path, path.name or str(path))
        name, ok = get_name(self, "Rename Favorite", "Name", current)
        if ok and name.strip():
            self.favorite_names[path] = name.strip()
            self._populate_shortcuts()
            self._favorites_changed()

    def move_favorite(self, path: Path, offset: int) -> None:
        if path not in self.favorites:
            return
        index = self.favorites.index(path)
        new_index = max(0, min(len(self.favorites) - 1, index + offset))
        if index == new_index:
            return
        self.favorites.insert(new_index, self.favorites.pop(index))
        self._populate_shortcuts()
        self._favorites_changed()

    def _favorites_changed(self) -> None:
        if self.favorites_changed_callback:
            self.favorites_changed_callback(self.favorites, self.favorite_names)

    def _recent_changed(self) -> None:
        if self.recent_changed_callback:
            self.recent_changed_callback(self.recent_paths)

    def _populate_shortcuts(self) -> None:
        places = [
            ("Home", Path.home(), QStyle.StandardPixmap.SP_DirHomeIcon),
            ("Desktop", Path.home() / "Desktop", QStyle.StandardPixmap.SP_DesktopIcon),
            ("Downloads", Path.home() / "Downloads", QStyle.StandardPixmap.SP_DirIcon),
            ("Documents", Path.home() / "Documents", QStyle.StandardPixmap.SP_FileDialogDetailedView),
            ("Pictures", Path.home() / "Pictures", QStyle.StandardPixmap.SP_FileDialogContentsView),
            ("Music", Path.home() / "Music", QStyle.StandardPixmap.SP_MediaVolume),
            ("Videos", Path.home() / "Videos", QStyle.StandardPixmap.SP_MediaPlay),
            ("tmp", Path.home() / "tmp", QStyle.StandardPixmap.SP_DirIcon),
            ("scripts", Path.home() / "scripts", QStyle.StandardPixmap.SP_FileIcon),
            ("Trash", Path.home() / ".local" / "share" / "Trash" / "files", QStyle.StandardPixmap.SP_TrashIcon),
            ("Root", Path("/"), QStyle.StandardPixmap.SP_DriveHDIcon),
        ]
        self.shortcuts.clear()
        for path in self.favorites:
            if path.exists():
                item = QListWidgetItem(self.favorite_names.get(path, path.name or str(path)))
                item.setIcon(self._shortcut_icon("Favorite", path, QStyle.StandardPixmap.SP_DirIcon))
                item.setData(Qt.ItemDataRole.UserRole, str(path))
                item.setData(Qt.ItemDataRole.UserRole + 1, True)
                item.setData(Qt.ItemDataRole.UserRole + 2, "favorite")
                item.setToolTip(str(path))
                self.shortcuts.addItem(item)
        if self.favorites:
            separator = QListWidgetItem("Places")
            separator.setFlags(Qt.ItemFlag.NoItemFlags)
            self.shortcuts.addItem(separator)
        for label, path, fallback_icon in places:
            if path.exists() and path.is_dir():
                item = QListWidgetItem(label)
                item.setIcon(self._shortcut_icon(label, path, fallback_icon))
                item.setData(Qt.ItemDataRole.UserRole, str(path))
                item.setData(Qt.ItemDataRole.UserRole + 1, False)
                item.setData(Qt.ItemDataRole.UserRole + 2, "place")
                item.setToolTip(str(path))
                self.shortcuts.addItem(item)
        if self.recent_paths:
            separator = QListWidgetItem("Recent")
            separator.setFlags(Qt.ItemFlag.NoItemFlags)
            self.shortcuts.addItem(separator)
            for path in self.recent_paths:
                item = QListWidgetItem(path.name or str(path))
                item.setIcon(self._shortcut_icon("Recent", path, QStyle.StandardPixmap.SP_DirIcon))
                item.setData(Qt.ItemDataRole.UserRole, str(path))
                item.setData(Qt.ItemDataRole.UserRole + 1, False)
                item.setData(Qt.ItemDataRole.UserRole + 2, "recent")
                item.setToolTip(str(path))
                self.shortcuts.addItem(item)

    def _shortcut_icon(self, label: str, path: Path, fallback_icon: QStyle.StandardPixmap):
        theme_names = {
            "Home": "user-home",
            "Desktop": "user-desktop",
            "Downloads": "folder-download",
            "Documents": "folder-documents",
            "Pictures": "folder-pictures",
            "Music": "folder-music",
            "Videos": "folder-videos",
            "Root": "drive-harddisk",
        }
        theme_icon = QIcon.fromTheme(theme_names.get(label, "folder"))
        if not theme_icon.isNull():
            return theme_icon
        file_icon = self.icon_provider.icon(QFileInfo(str(path)))
        if not file_icon.isNull():
            return file_icon
        return self.style().standardIcon(fallback_icon)

    def _open_shortcut(self, item: QListWidgetItem) -> None:
        if not item.flags() & Qt.ItemFlag.ItemIsEnabled:
            return
        path = Path(str(item.data(Qt.ItemDataRole.UserRole)))
        self.open_path_callback(path)

    def _show_shortcut_menu(self, position) -> None:
        item = self.shortcuts.itemAt(position)
        if not item:
            return
        item_type = str(item.data(Qt.ItemDataRole.UserRole + 2) or "")
        if item_type not in {"favorite", "recent"}:
            return
        path = Path(str(item.data(Qt.ItemDataRole.UserRole)))
        menu = QMenu(self)
        if item_type == "favorite":
            menu.addAction(menu_icon(self, "edit-rename", QStyle.StandardPixmap.SP_FileDialogDetailedView), "Rename Favorite", lambda: self.rename_favorite(path))
            menu.addAction(menu_icon(self, "go-up", QStyle.StandardPixmap.SP_ArrowUp), "Move Up", lambda: self.move_favorite(path, -1))
            menu.addAction(menu_icon(self, "go-down", QStyle.StandardPixmap.SP_ArrowDown), "Move Down", lambda: self.move_favorite(path, 1))
            menu.addAction(menu_icon(self, "list-remove", QStyle.StandardPixmap.SP_DialogCancelButton), "Remove Favorite", lambda: self.remove_favorite(path))
        else:
            menu.addAction(menu_icon(self, "list-remove", QStyle.StandardPixmap.SP_DialogCancelButton), "Remove Recent", lambda: self.remove_recent(path))
            menu.addAction(menu_icon(self, "edit-clear", QStyle.StandardPixmap.SP_DialogResetButton), "Clear Recent", self.clear_recent)
        menu.exec(self.shortcuts.viewport().mapToGlobal(position))

    def _show_tree_menu(self, position) -> None:
        index = self.tree.indexAt(position)
        if not index.isValid():
            return
        self.tree.setCurrentIndex(index)
        path = Path(self.tree_model.filePath(index))
        if not path.exists():
            return
        menu = QMenu(self)
        menu.addAction(menu_icon(self, ("document-open", "folder-open"), QStyle.StandardPixmap.SP_DialogOpenButton), "Open", lambda p=path: self.open_path_callback(p))
        if path.is_dir():
            menu.addAction(menu_icon(self, "bookmark-new", QStyle.StandardPixmap.SP_DialogYesButton), "Add to Favorites", lambda p=path: self.add_favorite(p))
            menu.addAction(menu_icon(self, "utilities-terminal", QStyle.StandardPixmap.SP_ComputerIcon), "Terminal Here", lambda p=path: self._open_terminal_at(p))
        menu.addAction(menu_icon(self, "accessories-calculator", QStyle.StandardPixmap.SP_FileDialogInfoView), "Calculate Size", lambda p=path: self._show_tree_size(p))
        menu.exec(self.tree.viewport().mapToGlobal(position))

    def _open_terminal_at(self, path: Path) -> None:
        window = self.window()
        if hasattr(window, "launch_terminal_at"):
            window.launch_terminal_at(path)

    def _show_tree_size(self, path: Path) -> None:
        size, files, folders = directory_size(path)
        QMessageBox.information(self, "Directory Size", f"Size: {readable_size(size)}\nFiles: {files}\nFolders: {folders}")

    @Slot(QModelIndex)
    def _open_tree_index(self, index: QModelIndex) -> None:
        if not index.isValid():
            return
        path = Path(self.tree_model.filePath(index))
        if path.is_dir():
            self.open_path_callback(path)


