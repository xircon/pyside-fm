        title_col.addWidget(subtitle_label)
        header.addWidget(icon_label)
        header.addLayout(title_col, 1)
        root.addLayout(header)

        general = QFormLayout()
        general.setLabelAlignment(Qt.AlignmentFlag.AlignRight)
        if len(paths) == 1:
            path = paths[0]
            info = QFileInfo(str(path))
            general.addRow("Name:", self._value(path.name or str(path)))
            general.addRow("Kind:", self._value("Folder" if path.is_dir() else "File"))
            general.addRow("Location:", self._value(str(path.parent)))
            if path.is_dir():
                general.addRow("Contents:", self._value(f"{files} files, {folders} folders"))
                general.addRow("Size:", self._value(f"{readable_size(total_size)} in direct contents"))
            else:
                general.addRow("Size:", self._value(readable_size(total_size)))
                self.default_app_mime = file_mime_type(path)
                general.addRow("MIME type:", self._value(self.default_app_mime))
            general.addRow("Modified:", self._value(info.lastModified().toString("yyyy-MM-dd HH:mm:ss")))
            general.addRow("Accessed:", self._value(info.lastRead().toString("yyyy-MM-dd HH:mm:ss")))
        else:
            general.addRow("Items:", self._value(str(len(paths))))
            general.addRow("Contents:", self._value(f"{files} files, {folders} folders"))
            general.addRow("Size:", self._value(readable_size(total_size)))
        root.addLayout(general)

        if len(paths) == 1:
            self.permission_path = paths[0]
            self.permission_boxes: dict[int, QCheckBox] = {}
            mode = self.permission_path.stat().st_mode
            permissions = QFormLayout()
            permissions.setLabelAlignment(Qt.AlignmentFlag.AlignRight)
            for label, bits in (
                ("Owner:", (stat.S_IRUSR, stat.S_IWUSR, stat.S_IXUSR)),
                ("Group:", (stat.S_IRGRP, stat.S_IWGRP, stat.S_IXGRP)),
                ("Other:", (stat.S_IROTH, stat.S_IWOTH, stat.S_IXOTH)),
            ):
                row = QHBoxLayout()
                for text, bit in zip(("Read", "Write", "Exec"), bits):
                    box = QCheckBox(text)
                    box.setChecked(bool(mode & bit))
                    self.permission_boxes[bit] = box
                    row.addWidget(box)
                row.addStretch(1)
                permissions.addRow(label, row)
            apply_permissions = QPushButton("Apply Permissions")
            apply_permissions.clicked.connect(lambda _checked=False, dialog=self: dialog.apply_permissions())
            permissions.addRow("", apply_permissions)
            root.addLayout(permissions)

        if len(paths) == 1 and paths[0].is_file():
            default_app = QFormLayout()
            default_app.setLabelAlignment(Qt.AlignmentFlag.AlignRight)
            self.default_app_combo = QComboBox()
            current_default = default_app_for_mime(self.default_app_mime)
            current_index = -1
            for name, _exec_line, icon_name, desktop_id in mime_apps_for(paths[0], limit=100):
                if not desktop_id:
                    continue
                label = f"{name} ({desktop_id})" if desktop_id == current_default else name
                self.default_app_combo.addItem(cached_desktop_icon(self, icon_name), label, desktop_id)
                if desktop_id == current_default:
                    current_index = self.default_app_combo.count() - 1
            if current_index >= 0:
                self.default_app_combo.setCurrentIndex(current_index)
            elif current_default:
                self.default_app_combo.insertItem(0, f"Current: {current_default}", current_default)
                self.default_app_combo.setCurrentIndex(0)
            if self.default_app_combo.count() == 0:
                self.default_app_combo.addItem("No matching applications", "")
                self.default_app_combo.setEnabled(False)
            set_default = QPushButton("Set Default")
            set_default.setEnabled(self.default_app_combo.isEnabled())
            set_default.clicked.connect(lambda _checked=False, dialog=self: dialog.apply_default_app())
            default_row = QHBoxLayout()
            default_row.addWidget(self.default_app_combo, 1)
            default_row.addWidget(set_default)
            default_app.addRow("Open with:", default_row)
            root.addLayout(default_app)

        buttons = QDialogButtonBox(QDialogButtonBox.StandardButton.Close)
        buttons.rejected.connect(lambda dialog=self: dialog.reject())
        root.addWidget(buttons)

    def _value(self, text: str) -> QLabel:
        label = QLabel(text)
        label.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
        label.setWordWrap(True)
        return label

    def apply_permissions(self) -> None:
        mode = 0
        for bit, box in self.permission_boxes.items():
            if box.isChecked():
                mode |= bit
        try:
            self.permission_path.chmod(mode)
        except OSError as exc:
            QMessageBox.warning(self, "Permissions Failed", str(exc))

    def apply_default_app(self) -> None:
        if not self.default_app_combo:
            return
        desktop_id = self.default_app_combo.currentData()
        if not desktop_id:
            return
        ok, message = set_default_app_for_mime(self.default_app_mime, str(desktop_id))
        if not ok:
            QMessageBox.warning(self, "Default Application Failed", message)
            return
        QMessageBox.information(self, "Default Application", "Default application updated.")

    def _measure(self, paths: list[Path]) -> tuple[int, int, int]:
        total_size = 0
        files = 0
        folders = 0
        for path in paths:
            if path.is_dir() and not path.is_symlink():
                try:
                    for child in path.iterdir():
                        if child.is_dir():
                            folders += 1
                        else:
                            files += 1
                            try:
                                total_size += child.stat().st_size
                            except OSError:
                                pass
                except OSError:
                    pass
            else:
                files += 1
                try:
                    total_size += path.stat().st_size
                except OSError:
                    pass
        return total_size, files, folders


class DropListView(QListView):
    def __init__(self, pane: "FilePane", parent: QWidget | None = None) -> None:
        super().__init__(parent)
        self.pane = pane
        self._drag_start_pos = None
        self._drag_start_index = QModelIndex()
        self.viewport().installEventFilter(self)

    def event(self, event) -> bool:
        if event.type() == QEvent.Type.ShortcutOverride and (self._is_plain_space(event) or self._is_plain_escape(event)):
            event.accept()
            return True
        if event.type() == QEvent.Type.KeyPress and self._handle_key(event):
            return True
        return super().event(event)

    def eventFilter(self, watched, event) -> bool:
        if watched is self.viewport() and event.type() == QEvent.Type.ShortcutOverride:
            if self._is_plain_space(event) or self._is_plain_escape(event):
                event.accept()
                return True
        if watched is self.viewport() and event.type() == QEvent.Type.KeyPress:
            if self._handle_key(event):
                return True
        if watched is self.viewport() and event.type() in {
            QEvent.Type.MouseButtonRelease,
            QEvent.Type.ContextMenu,
        }:
            if event.type() == QEvent.Type.ContextMenu:
                position = event.pos()
                self.pane._show_context_menu_for_view(self, position)
                event.accept()
                return True
            if event.button() == Qt.MouseButton.RightButton:
                position = event.position().toPoint()
                index = self.indexAt(position)
                if index.isValid():
                    self.setCurrentIndex(index)
                    self.selectionModel().select(
                        index,
                        QItemSelectionModel.SelectionFlag.ClearAndSelect | QItemSelectionModel.SelectionFlag.Rows,
                    )
                self.pane._show_context_menu_for_view(self, position)
                event.accept()
                return True
        return super().eventFilter(watched, event)

    def _is_plain_space(self, event) -> bool:
        return event.key() == Qt.Key.Key_Space and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_escape(self, event) -> bool:
        return event.key() == Qt.Key.Key_Escape and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _handle_key(self, event) -> bool:
        if self._is_plain_space(event):
            self.pane.toggle_current_tag()
            event.accept()
            return True
        if self._is_plain_escape(event):
            self.pane.clear_selection()
            event.accept()
            return True
        return False

    def selectionCommand(self, index: QModelIndex, event=None):
        if event is not None and event.type() in {QEvent.Type.ShortcutOverride, QEvent.Type.KeyPress}:
            if self._is_plain_space(event) or self._is_plain_escape(event):
                return QItemSelectionModel.SelectionFlag.NoUpdate
        return super().selectionCommand(index, event)

    def indexAt(self, point: QPoint) -> QModelIndex:
        index = super().indexAt(point)
        if not index.isValid() or self.viewMode() != QListView.ViewMode.IconMode:
            return index
        if self._icon_item_hit_rect(index).contains(point):
            return index
        return QModelIndex()

    def _icon_item_hit_rect(self, index: QModelIndex) -> QRect:
        margin = IconViewDelegate.ITEM_MARGIN
        return super().visualRect(index).adjusted(margin, margin, -margin, -margin)

    def mousePressEvent(self, event) -> None:
