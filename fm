        super().__init__(parent)
        self.pane = pane
        self._drag_start_pos = None
        self._drag_start_index = QModelIndex()
        self.viewport().installEventFilter(self)

    def event(self, event) -> bool:
        if event.type() == QEvent.Type.ShortcutOverride and (self._is_plain_space(event) or self._is_plain_escape(event)):
            event.accept()
            return True
        if event.type() == QEvent.Type.KeyPress and self._handle_key(event):
            return True
        return super().event(event)

    def eventFilter(self, watched, event) -> bool:
        if watched is self.viewport() and event.type() == QEvent.Type.ShortcutOverride:
            if self._is_plain_space(event) or self._is_plain_escape(event):
                event.accept()
                return True
        if watched is self.viewport() and event.type() == QEvent.Type.KeyPress:
            if self._handle_key(event):
                return True
        if watched is self.viewport() and event.type() in {
            QEvent.Type.MouseButtonRelease,
            QEvent.Type.ContextMenu,
        }:
            if event.type() == QEvent.Type.ContextMenu:
                position = event.pos()
                self.pane._show_context_menu_for_view(self, position)
                event.accept()
                return True
            if event.button() == Qt.MouseButton.RightButton:
                position = event.position().toPoint()
                index = self.indexAt(position)
                if index.isValid():
                    self.setCurrentIndex(index)
                    self.selectionModel().select(
                        index,
                        QItemSelectionModel.SelectionFlag.ClearAndSelect | QItemSelectionModel.SelectionFlag.Rows,
                    )
                self.pane._show_context_menu_for_view(self, position)
                event.accept()
                return True
        return super().eventFilter(watched, event)

