        paths = [path for path in self.copy_buffer if path.exists()]
        if not paths:
            mime = QApplication.clipboard().mimeData()
            paths = [Path(url.toLocalFile()) for url in mime.urls() if url.isLocalFile()]
        if paths:
            self.active_pane.copy_paths_to(paths, self.active_pane.current_path())

