        try:
            recent = path.expanduser().resolve()
        except OSError:
            recent = path.expanduser()
        if not recent.exists() or not recent.is_dir():
            return
        paths = [item for item in self.side_panel.recent_paths if item != recent]
        paths.insert(0, recent)
        self.side_panel.set_recent_paths(paths[:10])
        self.save_recent_paths(self.side_panel.recent_paths)

