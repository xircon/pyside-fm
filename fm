    def _wire_focus(self, pane: FilePane) -> None:
        for widget in [pane.path_edit, pane.search_edit, pane.icon_view, pane.list_view, pane.detail_view]:
            widget.installEventFilter(self)
        for view in [pane.icon_view, pane.list_view, pane.detail_view]:
            view.viewport().installEventFilter(self)

    def eventFilter(self, watched, event) -> bool:
        if watched is getattr(self, "side_dock", None) and event.type() == QEvent.Type.Resize:
            if self.side_dock.isVisible() and not self._restoring_side_panel_width:
                self.side_panel_width = max(80, self.side_dock.width())
        if event.type() == QEvent.Type.KeyPress and self.handle_manual_preview_key(event):
            event.accept()
            return True
        if event.type() == QEvent.Type.KeyPress and self._is_plain_escape(event) and self.close_manual_previews():
            event.accept()
            return True
        if event.type() in {QEvent.Type.ShortcutOverride, QEvent.Type.KeyPress}:
            zoom_target = self._pane_zoom_target(watched) if self._is_plain_z(event) else None
            if zoom_target:
                if event.type() == QEvent.Type.KeyPress:
                    self.set_active_pane(zoom_target)
                    self.toggle_pane_zoom()
                event.accept()
                return True
            if self._is_plain_space(event) and self._space_targets_tag(watched):
                if event.type() == QEvent.Type.KeyPress:
                    self.active_pane.toggle_current_tag()
                event.accept()
                return True
            if self._is_plain_p(event) and self._space_targets_tag(watched):
                path = self.active_pane.current_item_path()
                if path and path.is_file() and is_previewable_file(path):
                    if event.type() == QEvent.Type.KeyPress:
                        self.active_pane.preview_selected_in_peer()
                    event.accept()
                    return True
            if self._is_plain_o(event) and self._space_targets_tag(watched):
                if self.active_pane.current_item_path():
                    if event.type() == QEvent.Type.KeyPress:
                        self.active_pane.open_selected()
                    event.accept()
                    return True
            if self._is_plain_r(event) and self._space_targets_tag(watched):
                if event.type() == QEvent.Type.KeyPress:
                    self.active_pane.show_properties()
                event.accept()
                return True
            if self._is_plain_e(event) and self._space_targets_tag(watched):
                path = self.active_pane.current_item_path()
                if path and path.is_dir():
                    if event.type() == QEvent.Type.KeyPress:
                        self.active_pane.show_emblem_menu_for_current()
                    event.accept()
                    return True
            if self._is_plain_escape(event) and self._space_targets_tag(watched):
                if event.type() == QEvent.Type.KeyPress:
                    if self.close_manual_previews():
                        event.accept()
                        return True
                    self.active_pane.clear_selection()
                event.accept()
                return True
        if event.type() == QEvent.Type.FocusIn:
            if watched in {
                self.left.path_edit,
                self.left.search_edit,
                self.left.icon_view,
                self.left.icon_view.viewport(),
                self.left.list_view,
                self.left.list_view.viewport(),
                self.left.detail_view,
                self.left.detail_view.viewport(),
            }:
                self.set_active_pane(self.left)
            elif watched in {
                self.right.path_edit,
                self.right.search_edit,
                self.right.icon_view,
                self.right.icon_view.viewport(),
                self.right.list_view,
                self.right.list_view.viewport(),
                self.right.detail_view,
                self.right.detail_view.viewport(),
            }:
                self.set_active_pane(self.right)
        return super().eventFilter(watched, event)

    def _is_plain_space(self, event) -> bool:
        return event.key() == Qt.Key.Key_Space and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_escape(self, event) -> bool:
        return event.key() == Qt.Key.Key_Escape and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_z(self, event) -> bool:
        return event.key() == Qt.Key.Key_Z and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_p(self, event) -> bool:
        return event.key() == Qt.Key.Key_P and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_o(self, event) -> bool:
        return event.key() == Qt.Key.Key_O and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_r(self, event) -> bool:
        return event.key() == Qt.Key.Key_R and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _is_plain_e(self, event) -> bool:
        return event.key() == Qt.Key.Key_E and event.modifiers() == Qt.KeyboardModifier.NoModifier

    def _space_targets_tag(self, watched) -> bool:
        pane = self.active_pane
        view = pane.current_view()
        if view not in pane.views:
            return False
        viewport = view.viewport()
        focus = QApplication.focusWidget()
        if watched in {view, viewport}:
            return True
        if focus in {view, viewport}:
            return True
        return bool(focus and view.isAncestorOf(focus))

    def _pane_zoom_target(self, watched) -> FilePane | None:
        if QApplication.focusWidget() in {self.left.path_edit, self.left.search_edit, self.right.path_edit, self.right.search_edit}:
            return None
        if self.active_pane.manual_preview_active:
            return self.active_pane
        if self._space_targets_tag(watched):
            return self.active_pane
        focus = QApplication.focusWidget()
        for pane in (self.left, self.right):
            preview_widgets = {
                pane.full_preview_stack,
                pane.full_preview_image,
                pane.full_preview_scroll,
                pane.full_preview_label,
                pane.full_preview_text,
                pane.pdf_controls,
                pane.pdf_prev_button,
                pane.pdf_page_label,
                pane.pdf_next_button,
            }
            if watched in preview_widgets or focus in preview_widgets:
                return pane
            if focus and any(widget.isAncestorOf(focus) for widget in preview_widgets):
                return pane
        return None

    def set_active_pane(self, pane: FilePane) -> None:
        if self.active_pane is pane:
            return
        self.active_pane = pane
        self._update_active_pane_style()

    def toggle_pane_zoom(self) -> None:
        if self.zoomed_pane is self.active_pane:
            self.clear_pane_zoom()
            return
        self.zoom_pane(self.active_pane)

    def zoom_pane(self, pane: FilePane) -> None:
        if pane not in {self.left, self.right}:
            return
        if not self.pre_zoom_splitter_sizes:
            self.pre_zoom_splitter_sizes = self.splitter.sizes()
        self.zoomed_pane = pane
        total = max(sum(self.splitter.sizes()), self.splitter.width(), 1)
        if pane is self.left:
            self.splitter.setSizes([total, 0])
        else:
            self.splitter.setSizes([0, total])
        self._update_active_pane_style()

    def clear_pane_zoom(self) -> None:
        if not self.zoomed_pane:
            return
        restore_sizes = self.pre_zoom_splitter_sizes or [1, 1]
        self.zoomed_pane = None
        self.pre_zoom_splitter_sizes = []
        self.splitter.setSizes(restore_sizes)
        self._update_active_pane_style()

    def _update_active_pane_style(self) -> None:
        for pane in (self.left, self.right):
            pane.setProperty("active", pane is self.active_pane)
            pane.setProperty("zoomed", pane is self.zoomed_pane)
            pane.style().unpolish(pane)
            pane.style().polish(pane)
            pane.update()

    def restore_settings(self) -> None:
        geometry = self.settings.value("geometry")
        if geometry:
            self.restoreGeometry(geometry)
        window_state = self.settings.value("windowState")
        if window_state:
            self.restoreState(window_state)
        splitter_state = self.settings.value("splitter")
        if splitter_state:
            self.splitter.restoreState(splitter_state)

        left_state = self.cli_left_state or PaneState(
            Path(str(self.settings.value("left/path", str(Path.home())))),
            str(self.settings.value("left/view", "Details")),
        )
        right_state = self.cli_right_state or PaneState(
            Path(str(self.settings.value("right/path", str(Path.home())))),
            str(self.settings.value("right/view", "Details")),
        )
        self.left.restore_state(left_state)
        self.right.restore_state(right_state)
        self.left.set_icon_zoom(int(self.settings.value("left/iconZoom", self.left.icon_zoom)))
        self.right.set_icon_zoom(int(self.settings.value("right/iconZoom", self.right.icon_zoom)))
        try:
            favorite_names = json.loads(str(self.settings.value("favoriteNamesJson", "{}")))
        except json.JSONDecodeError:
            favorite_names = {}
        self.side_panel.set_favorites(
            [Path(value) for value in self.settings.value("favorites", [], type=list)],
            {str(key): str(value) for key, value in favorite_names.items()},
        )
        self.side_panel.set_recent_paths([Path(value) for value in self.settings.value("recentPaths", [], type=list)])
        self.set_show_hidden(self.show_hidden)
        self.set_preview_enabled(self.preview_enabled)
        self.left.restore_preview_state(self.settings.value("left/previewSplitter"))
        self.right.restore_preview_state(self.settings.value("right/previewSplitter"))
        self.side_dock.setVisible(str(self.settings.value("sidePanel/visible", "true")).lower() != "false")
        self.side_panel.set_mode(str(self.settings.value("sidePanel/mode", "Shortcuts")))
        self.side_panel_width = int(self.settings.value("sidePanel/width", self.side_panel_width or 180))
        self.schedule_side_panel_width_restore(self.side_panel_width)
        self.apply_theme(self.current_theme)

    def save_settings(self) -> None:
        if self.zoomed_pane:
            self.clear_pane_zoom()
        self.settings.setValue("geometry", self.saveGeometry())
        self.settings.setValue("windowState", self.saveState())
        self.settings.setValue("splitter", self.splitter.saveState())
        self.settings.setValue("theme", self.current_theme)
        self.settings.setValue("showHidden", self.show_hidden)
        self.settings.setValue("iconLayout", self.icon_layout)
        self.settings.setValue("favorites", [str(path) for path in self.side_panel.favorites])
        self.settings.setValue("favoriteNamesJson", json.dumps({str(path): name for path, name in self.side_panel.favorite_names.items()}))
        self.settings.setValue("recentPaths", [str(path) for path in self.side_panel.recent_paths])
        self.settings.setValue("previewEnabled", self.preview_enabled)
        self.settings.setValue("terminal/command", self.terminal_command)
        self.settings.setValue("terminal/args", self.terminal_args)
        self.settings.setValue("userButtonsJson", json.dumps(self.user_buttons))
        self.settings.setValue("dualBookmarksJson", json.dumps(self.dual_bookmarks))
        self.settings.setValue("folderEmblemsJson", json.dumps(self.folder_emblems))
        self.settings.setValue("sidePanel/visible", self.side_dock.isVisible())
        self.settings.setValue("sidePanel/mode", self.side_panel.current_mode())
        if self.side_dock.isVisible():
            self.side_panel_width = max(80, self.side_dock.width())
        self.settings.setValue("sidePanel/width", self.side_panel_width)
        for prefix, pane in (("left", self.left), ("right", self.right)):
            state = pane.state()
            self.settings.setValue(f"{prefix}/path", str(state.path))
            self.settings.setValue(f"{prefix}/view", state.view_mode)
            self.settings.setValue(f"{prefix}/iconZoom", pane.icon_zoom)
            self.settings.setValue(f"{prefix}/previewSplitter", pane.preview_state())
        self.settings.sync()

    def schedule_side_panel_width_restore(self, width: int) -> None:
        target_width = max(80, width)
        QTimer.singleShot(0, lambda window=self, saved_width=target_width: window.restore_side_panel_width(saved_width))
        QTimer.singleShot(100, lambda window=self, saved_width=target_width: window.restore_side_panel_width(saved_width))

    def restore_side_panel_width(self, width: int) -> None:
        self.side_panel_width = max(80, width)
        if self.side_dock.isVisible():
            self._restoring_side_panel_width = True
            try:
                self.resizeDocks([self.side_dock], [self.side_panel_width], Qt.Orientation.Horizontal)
            finally:
                QTimer.singleShot(0, lambda window=self: setattr(window, "_restoring_side_panel_width", False))

    def showEvent(self, event) -> None:
        super().showEvent(event)
        self.schedule_side_panel_width_restore(self.side_panel_width)

    def closeEvent(self, event) -> None:
        if self.active_file_operations > 0:
            response = QMessageBox.question(
                self,
                "File Operation in Progress",
                "A copy or move operation is still running. Quit anyway?",
                QMessageBox.StandardButton.No | QMessageBox.StandardButton.Yes,
                QMessageBox.StandardButton.No,
            )
            if response != QMessageBox.StandardButton.Yes:
                event.ignore()
                return
        self.save_settings()
        super().closeEvent(event)

    def begin_file_operation(self) -> None:
        self.active_file_operations += 1

    def end_file_operation(self) -> None:
        self.active_file_operations = max(0, self.active_file_operations - 1)
        if self.active_file_operations == 0 and self.operation_queue:
            _name, callback = self.operation_queue.pop(0)
            self.running_queued_operation = True
            QTimer.singleShot(0, lambda cb=callback: self._run_queued_operation(cb))

    def queue_file_operation(self, name: str, callback) -> bool:
        if self.active_file_operations > 0 and not self.running_queued_operation:
            self.operation_queue.append((name, callback))
            QMessageBox.information(self, "Operation Queued", f"Queued: {name}")
            return True
        return False

    def _run_queued_operation(self, callback) -> None:
        try:
            callback()
        finally:
            self.running_queued_operation = False

    def apply_theme(self, theme: str) -> None:
        self.current_theme = theme if theme in THEMES else "Dark"
        app = QApplication.instance()
        if app:
            app.setStyleSheet(THEME_STYLES[self.current_theme])

    def set_icon_layout(self, layout: str) -> None:
        self.icon_layout = layout if layout in ICON_LAYOUTS else "Normal"
        self.left.set_icon_layout(self.icon_layout)
        self.right.set_icon_layout(self.icon_layout)

    def open_settings(self) -> None:
        dialog = SettingsDialog(
            self.current_theme,
            self.icon_layout,
            self.terminal_command,
            self.terminal_args,
            self.user_buttons,
            self.dual_bookmarks,
            self,
        )
        if dialog.exec() != QDialog.DialogCode.Accepted:
            return
        self.apply_theme(dialog.theme())
        self.set_icon_layout(dialog.icon_layout())
        self.terminal_command = dialog.terminal_command()
        self.terminal_args = dialog.terminal_args()
        self.user_buttons = dialog.user_buttons()
        self.dual_bookmarks = dialog.dual_bookmarks()
        self._populate_user_toolbar_buttons()
        self._populate_dual_bookmark_combo()
        self.settings.setValue("theme", self.current_theme)
        self.settings.setValue("iconLayout", self.icon_layout)
        self.settings.setValue("terminal/command", self.terminal_command)
        self.settings.setValue("terminal/args", self.terminal_args)
        self.settings.setValue("userButtonsJson", json.dumps(self.user_buttons))
        self.settings.setValue("dualBookmarksJson", json.dumps(self.dual_bookmarks))
        self.settings.sync()

