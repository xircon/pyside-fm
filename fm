    def preview_selected_in_peer(self) -> None:
        path = self.current_item_path()
        if self.peer and path and path.is_file():
            self.peer.show_manual_preview(path)
            window = self.window()
            if hasattr(window, "set_active_pane"):
                window.set_active_pane(self.peer)

    def copy_paths_to(self, paths: list[Path], destination: Path) -> None:
        if not paths:
            return
        window = self.window()
        if hasattr(window, "queue_file_operation") and window.queue_file_operation(
            "Copy files", lambda p=list(paths), d=destination, pane=self: pane.copy_paths_to(p, d)
        ):
            return
        targets: list[tuple[Path, Path]] = []
        for path in paths:
            target = choose_existing_destination(self, path, destination / path.name)
            if target is None:
                return
            targets.append((path, target))
        self._start_file_operation("copy", targets, "Copying files...", "created")

    def move_paths_to(self, paths: list[Path], destination: Path) -> None:
        if not paths:
            return
        window = self.window()
        if hasattr(window, "queue_file_operation") and window.queue_file_operation(
            "Move files", lambda p=list(paths), d=destination, pane=self: pane.move_paths_to(p, d)
        ):
            return
        targets: list[tuple[Path, Path]] = []
        for path in paths:
            target = choose_existing_destination(self, path, destination / path.name)
            if target is None:
                return
            targets.append((path, target))
        self._start_file_operation("move", targets, "Moving files...", "move")

    def _start_file_operation(self, operation: str, targets: list[tuple[Path, Path]], title: str, undo_kind: str) -> None:
        if not targets:
            return
        window = self.window()
        if hasattr(window, "begin_file_operation"):
            window.begin_file_operation()

        progress = QProgressDialog("Preparing...", "Cancel", 0, 0, self)
        widen_progress_dialog(progress)
        progress.setWindowModality(Qt.WindowModality.NonModal)
        progress.setMinimumDuration(0)
        progress.setAutoClose(False)
        progress.setAutoReset(False)
        progress.setWindowTitle(title)
        progress.show()

        thread = QThread(self)
        worker = FileOperationWorker(operation, targets)
        worker.moveToThread(thread)
        self._operation_threads.append(thread)
        self._operation_workers.append(worker)
        self._operation_contexts[worker] = {
            "progress": progress,
            "thread": thread,
            "window": window,
            "undo_kind": undo_kind,
            "operation": operation,
        }

        worker.progress.connect(self._file_operation_progress)
        worker.completed.connect(self._file_operation_completed)
        worker.canceled.connect(self._file_operation_canceled)
        worker.failed.connect(self._file_operation_failed)
        progress.canceled.connect(worker.cancel)
        thread.started.connect(worker.run)
        thread.finished.connect(worker.deleteLater)
        thread.finished.connect(thread.deleteLater)
        thread.finished.connect(lambda t=thread: self._operation_threads.remove(t) if t in self._operation_threads else None)
        thread.finished.connect(lambda w=worker: self._cleanup_file_worker(w))
        thread.start()

    @Slot(int, int, str, object)
    def _file_operation_progress(self, value: int, maximum: int, label: str, speed: float) -> None:
        worker = self.sender()
        context = self._operation_contexts.get(worker)
        if not context:
            return
        progress = context["progress"]
        if not isinstance(progress, QProgressDialog):
            return
        if progress.maximum() != maximum:
            progress.setRange(0, maximum)
        speed_text = readable_size(int(speed)) + "/s" if speed and speed > 0 else "calculating speed..."
        progress.setLabelText(f"{label}\n{speed_text}")
        widen_progress_dialog(progress)
        progress.setValue(min(value, maximum))

    @Slot(str, object)
    def _file_operation_completed(self, _operation: str, completed: list[tuple[Path, Path]]) -> None:
        self._finish_file_operation(completed)

    @Slot(str, object)
    def _file_operation_canceled(self, _operation: str, completed: list[tuple[Path, Path]]) -> None:
        self._finish_file_operation(completed)

    @Slot(str, object)
    def _file_operation_failed(self, message: str, completed: list[tuple[Path, Path]]) -> None:
        self._finish_file_operation(completed, message)

    def _finish_file_operation(self, completed: list[tuple[Path, Path]], warning: str | None = None) -> None:
        worker = self.sender()
        context = self._operation_contexts.get(worker)
        if not context:
            return
        undo_kind = str(context["undo_kind"])
        operation = str(context["operation"])
        progress = context["progress"]
        thread = context["thread"]
        window = context["window"]
        if completed:
            self.record_undo(UndoAction(undo_kind, completed))
        if warning:
            QMessageBox.warning(self, f"{operation.title()} Failed", warning)
        if isinstance(progress, QProgressDialog):
            progress.close()
        if hasattr(window, "end_file_operation"):
            window.end_file_operation()
        if isinstance(thread, QThread):
            thread.quit()

    def _cleanup_file_worker(self, worker: FileOperationWorker) -> None:
        if worker in self._operation_workers:
            self._operation_workers.remove(worker)
        self._operation_contexts.pop(worker, None)

    def handle_drop(self, urls: list[QUrl], action: Qt.DropAction, target_index: QModelIndex) -> bool:
        paths = [Path(url.toLocalFile()) for url in urls if url.isLocalFile()]
        if not paths:
            return False

        destination = self.current_path()
        if target_index.isValid():
            target_path = Path(self.model.filePath(target_index))
            if target_path.is_dir():
                destination = target_path

        try:
            destination = destination.resolve()
        except OSError:
            pass

        filtered_paths = []
        for path in paths:
            try:
                resolved = path.resolve()
            except OSError:
                resolved = path
            if resolved == destination:
                continue
            if path.is_dir() and not path.is_symlink() and resolved in destination.parents:
                continue
            filtered_paths.append(path)
        if not filtered_paths:
            return False

        if action == Qt.DropAction.MoveAction:
            self.move_paths_to(filtered_paths, destination)
        else:
            self.copy_paths_to(filtered_paths, destination)
        return True

    def trash_selected(self) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            return
        window = self.window()
        if hasattr(window, "queue_file_operation") and window.queue_file_operation(
            "Move to trash", lambda pane=self: pane.trash_selected()
        ):
            return
        if hasattr(window, "begin_file_operation"):
            window.begin_file_operation()
        failed: list[Path] = []
        trashed: list[tuple[Path, Path]] = []
        try:
            progress = QProgressDialog("Moving items to trash...", "Cancel", 0, len(paths), self)
            widen_progress_dialog(progress)
            progress.setWindowModality(Qt.WindowModality.WindowModal)
            progress.setMinimumDuration(0)
            progress.setAutoClose(False)
            progress.setAutoReset(False)
            progress.show()
            started_at = time.monotonic()
            QApplication.processEvents()
            for row, path in enumerate(paths):
                progress.setValue(row)
                progress.setLabelText(f"Moving to trash: {path.name}")
                QApplication.processEvents()
                if progress.wasCanceled():
                    break
                try:
                    original = path.expanduser().resolve()
                except OSError:
                    original = path.expanduser()
                trash_path = move_to_trash(path)
                if trash_path:
                    trashed.append((trash_path, original))
                else:
                    failed.append(path)
            finish_visible_progress(progress, len(paths), started_at)
            if trashed and self.trash_callback:
                self.trash_callback(trashed)
            if trashed:
                self.record_undo(UndoAction("trash", trashed))
            if failed:
                QMessageBox.warning(self, "Trash Failed", "Could not trash:\n" + "\n".join(str(path) for path in failed))
        finally:
            if hasattr(window, "end_file_operation"):
                window.end_file_operation()

    def delete_permanently_selected(self) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            return
        window = self.window()
        if hasattr(window, "queue_file_operation") and window.queue_file_operation(
            "Delete permanently", lambda pane=self: pane.delete_permanently_selected()
        ):
            return
        response = QMessageBox.question(
            self,
            "Delete Permanently",
            f"Permanently delete {len(paths)} item(s)?",
            QMessageBox.StandardButton.Cancel | QMessageBox.StandardButton.Yes,
            QMessageBox.StandardButton.Cancel,
        )
        if response != QMessageBox.StandardButton.Yes:
            return
        if hasattr(window, "begin_file_operation"):
            window.begin_file_operation()
        try:
            progress = QProgressDialog("Deleting items...", "Cancel", 0, len(paths), self)
            widen_progress_dialog(progress)
            progress.setWindowModality(Qt.WindowModality.WindowModal)
            progress.setMinimumDuration(0)
            progress.setAutoClose(False)
            progress.setAutoReset(False)
            progress.show()
            started_at = time.monotonic()
            QApplication.processEvents()
            for row, path in enumerate(paths):
                progress.setValue(row)
                progress.setLabelText(f"Deleting: {path.name}")
                QApplication.processEvents()
                if progress.wasCanceled():
                    break
                try:
                    remove_existing(path)
                except OSError as exc:
                    finish_visible_progress(progress, row, started_at)
                    QMessageBox.warning(self, "Delete Failed", f"{path}\n\n{exc}")
                    return
            finish_visible_progress(progress, len(paths), started_at)
        finally:
            if hasattr(window, "end_file_operation"):
                window.end_file_operation()

