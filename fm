class IconViewDelegate(QStyledItemDelegate):
    ITEM_MARGIN = 8

    @staticmethod
    def item_size(icon_size: QSize, layout: str = "Normal") -> QSize:
        min_width, min_height, width_extra, height_extra = ICON_LAYOUT_METRICS.get(layout, ICON_LAYOUT_METRICS["Normal"])
        return QSize(max(min_width, icon_size.width() + width_extra), max(min_height, icon_size.height() + height_extra))

    def paint(self, painter: QPainter, option: QStyleOptionViewItem, index: QModelIndex) -> None:
        opt = QStyleOptionViewItem(option)
        self.initStyleOption(opt, index)
        painter.save()
        item_rect = opt.rect.adjusted(self.ITEM_MARGIN, self.ITEM_MARGIN, -self.ITEM_MARGIN, -self.ITEM_MARGIN)

        if opt.state & QStyle.StateFlag.State_Selected:
            painter.fillRect(item_rect, opt.palette.highlight())
            text_color = opt.palette.highlightedText().color()
        else:
            if opt.backgroundBrush.style() != Qt.BrushStyle.NoBrush:
                painter.fillRect(item_rect, opt.backgroundBrush)
            text_color = opt.palette.text().color()

        icon_size = opt.decorationSize if opt.decorationSize.isValid() else QSize(64, 64)
        icon_rect = QRect(item_rect.x(), item_rect.y() + 8, item_rect.width(), icon_size.height())
        pixmap = opt.icon.pixmap(icon_size)
        if not pixmap.isNull():
            x = icon_rect.x() + (icon_rect.width() - pixmap.width()) // 2
            painter.drawPixmap(x, icon_rect.y(), pixmap)

        text_top = icon_rect.bottom() + 8
        line_height = opt.fontMetrics.lineSpacing()
        text_rect = QRect(item_rect.x() + 6, text_top, max(20, item_rect.width() - 12), line_height * 3 + 2)
        painter.setPen(text_color)
        painter.setFont(opt.font)
        painter.drawText(
            text_rect,
            Qt.AlignmentFlag.AlignHCenter | Qt.AlignmentFlag.AlignTop | Qt.TextFlag.TextWordWrap | Qt.TextFlag.TextWrapAnywhere,
            opt.text,
        )
        painter.restore()

    def sizeHint(self, option: QStyleOptionViewItem, index: QModelIndex) -> QSize:
        hint = super().sizeHint(option, index)
        icon_size = option.decorationSize if option.decorationSize.isValid() else QSize(64, 64)
        view = self.parent()
        layout = getattr(view, "icon_layout", "Normal")
        item_size = self.item_size(icon_size, layout)
        return QSize(max(hint.width(), item_size.width()), max(hint.height(), item_size.height()))


