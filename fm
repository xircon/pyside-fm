def folder_icon_with_emblem(base_icon: QIcon, emblem_key: str, size: int = 96) -> QIcon:
    base = base_icon.pixmap(size, size)
    if base.isNull():
        return emblem_icon(emblem_key, size)
    canvas = QPixmap(size, size)
    canvas.fill(Qt.GlobalColor.transparent)
    painter = QPainter(canvas)
    painter.setRenderHint(QPainter.RenderHint.Antialiasing)
    x = (size - base.width()) // 2
    y = (size - base.height()) // 2
    painter.drawPixmap(x, y, base)
    emblem_size = max(20, size // 3)
    badge = emblem_icon(emblem_key, emblem_size).pixmap(emblem_size, emblem_size)
    painter.drawPixmap(size - emblem_size - 2, size - emblem_size - 2, badge)
    painter.end()
    return QIcon(canvas)


