    def empty_trash(self) -> None:
        trash_root = Path.home() / ".local" / "share" / "Trash"
        files_dir = trash_root / "files"
        info_dir = trash_root / "info"
        trash_items = list(files_dir.iterdir()) if files_dir.exists() else []
        info_items = list(info_dir.iterdir()) if info_dir.exists() else []
        if not trash_items and not info_items:
            QMessageBox.information(self, "Empty Trash", "Trash is already empty.")
            return
        response = QMessageBox.question(
            self,
            "Empty Trash",
            f"Permanently delete {len(trash_items)} trashed item(s)?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.No,
        )
        if response != QMessageBox.StandardButton.Yes:
            return
        failed: list[str] = []
        for path in trash_items:
            try:
                remove_existing(path)
            except OSError as exc:
                failed.append(f"{path}: {exc}")
        for path in info_items:
            try:
                path.unlink()
            except OSError as exc:
                failed.append(f"{path}: {exc}")
        self.left.refresh()
        self.right.refresh()
        if failed:
            QMessageBox.warning(self, "Empty Trash Failed", "\n".join(failed))

    def record_trashed(self, items: list[tuple[Path, Path]]) -> None:
        # Trash actions are recorded by FilePane so all undoable operations use one stack.
        pass

    def record_undo(self, action: UndoAction) -> None:
        self.undo_stack.append(action)
        if len(self.undo_stack) > 50:
            self.undo_stack = self.undo_stack[-50:]

    def undo_last_action(self) -> None:
        if not self.undo_stack:
            return
        action = self.undo_stack.pop()
        failed: list[str] = []
        if action.kind == "created":
            for created_path, _unused in reversed(action.items):
                try:
                    if created_path.exists() or created_path.is_symlink():
                        remove_existing(created_path)
                except OSError as exc:
                    failed.append(f"{created_path}: {exc}")
        elif action.kind in {"move", "rename"}:
            for current_path, original_path in reversed(action.items):
                try:
                    original_path.parent.mkdir(parents=True, exist_ok=True)
                    restore_path = original_path
                    if restore_path.exists():
                        restore_path = unique_destination(original_path.parent, original_path.name)
                    if current_path.exists() or current_path.is_symlink():
                        shutil.move(str(current_path), str(restore_path))
                except OSError as exc:
                    failed.append(f"{current_path} -> {original_path}: {exc}")
        elif action.kind == "trash":
            self._undo_trash(action.items, failed)
        if failed:
            QMessageBox.warning(self, "Undo Failed", "\n".join(failed))

    def _undo_trash(self, batch: list[tuple[Path, Path]], failed: list[str]) -> None:
        for trash_path, original_path in reversed(batch):
            try:
                original_path.parent.mkdir(parents=True, exist_ok=True)
                restore_path = original_path
                if restore_path.exists():
                    restore_path = unique_destination(original_path.parent, original_path.name)
                shutil.move(str(trash_path), str(restore_path))
                info_path = Path.home() / ".local" / "share" / "Trash" / "info" / f"{trash_path.name}.trashinfo"
                try:
                    info_path.unlink()
                except OSError:
                    pass
            except OSError as exc:
                failed.append(f"{trash_path} -> {original_path}: {exc}")

