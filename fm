        if not path:
            return
        name, ok = get_name(self, "Rename", "Name", path.name)
        if not ok or not name.strip() or name.strip() == path.name:
            return
        target = path.with_name(name.strip())
        try:
            path.rename(target)
            self.record_undo(UndoAction("rename", [(target, path)]))
        except OSError as exc:
            QMessageBox.warning(self, "Rename Failed", str(exc))

    def duplicate_selected(self) -> None:
        created: list[tuple[Path, Path]] = []
        for path in self.selected_or_current_paths():
            try:
                target = unique_destination(path.parent, f"{path.stem} copy{path.suffix}")
                copy_path(path, target)
                created.append((target, Path()))
            except OSError as exc:
                QMessageBox.warning(self, "Duplicate Failed", f"{path}\n\n{exc}")
                return
        if created:
            self.record_undo(UndoAction("created", created))

    def create_archive_selected(self) -> None:
        paths = self.selected_or_current_paths()
        if not paths:
            return
        default_name = f"{paths[0].stem if len(paths) == 1 else 'archive'}.zip"
        name, ok = get_name(self, "Create Archive", "Name", default_name)
        if not ok or not name.strip():
            return
        archive_path = self.current_path() / name.strip()
        if archive_path.suffix.lower() != ".zip":
            archive_path = archive_path.with_name(f"{archive_path.name}.zip")
        try:
            target = choose_existing_destination(self, paths[0], archive_path)
            if target is None:
                return
            create_zip_archive(paths, target)
            self.record_undo(UndoAction("created", [(target, Path())]))
        except (OSError, ValueError, zipfile.BadZipFile) as exc:
            QMessageBox.warning(self, "Archive Failed", str(exc))

    def extract_archives_here(self) -> None:
        archives = [path for path in self.selected_or_current_paths() if is_archive(path)]
        if not archives:
            QMessageBox.information(self, "Extract Archive", "Select one or more supported archives.")
            return
        created: list[tuple[Path, Path]] = []
        try:
            for archive in archives:
                target = unique_destination(self.current_path(), archive_base_name(archive))
                extract_archive(archive, target)
                created.append((target, Path()))
            if created:
                self.record_undo(UndoAction("created", created))
        except (OSError, ValueError, tarfile.TarError, zipfile.BadZipFile) as exc:
            QMessageBox.warning(self, "Extract Failed", str(exc))

    def extract_archive_to_folder(self) -> None:
        archive = self.current_item_path()
        if not archive or not is_archive(archive):
            QMessageBox.information(self, "Extract Archive", "Select a supported archive.")
            return
        default_name = archive_base_name(archive)
        name, ok = get_name(self, "Extract To", "Folder", default_name)
        if not ok or not name.strip():
            return
        target = self.current_path() / name.strip()
        try:
            if target.exists():
                target = choose_existing_destination(self, archive, target)
                if target is None:
                    return
            extract_archive(archive, target)
            self.record_undo(UndoAction("created", [(target, Path())]))
        except (OSError, ValueError, tarfile.TarError, zipfile.BadZipFile) as exc:
            QMessageBox.warning(self, "Extract Failed", str(exc))

